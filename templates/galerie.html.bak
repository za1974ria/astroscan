<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GALERIE COSMIQUE — AstroScan</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap');
  :root { --acid:#00ff88; --amber:#ffaa00; --blue:#00aaff; --red:#ff4466; --bg:#020810; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:#e0e8ff; font-family:'Share Tech Mono',monospace; min-height:100vh; }
  .stars { position:fixed; inset:0; background:
    radial-gradient(ellipse at 20% 50%,rgba(0,100,255,.04) 0%,transparent 60%),
    radial-gradient(ellipse at 80% 20%,rgba(0,255,136,.04) 0%,transparent 60%); z-index:0; }
  header { position:relative; z-index:1; border-bottom:1px solid rgba(0,255,136,.2);
    padding:20px 40px; display:flex; justify-content:space-between; align-items:center;
    background:rgba(0,8,16,.9); }
  .logo { font-family:'Orbitron',monospace; font-size:22px; font-weight:900; letter-spacing:4px;
    background:linear-gradient(135deg,#00ff88,#00aaff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
  .nav a { color:#8899aa; text-decoration:none; margin-left:20px; font-size:12px; letter-spacing:2px; }
  .nav a:hover { color:var(--acid); }
  .stats { position:relative; z-index:1; display:grid; grid-template-columns:repeat(3,1fr);
    gap:1px; background:rgba(0,255,136,.1); margin:32px 40px 24px; border:1px solid rgba(0,255,136,.1); }
  .stat { background:rgba(2,8,16,.95); padding:20px; text-align:center; }
  .stat-val { font-family:'Orbitron',monospace; font-size:36px; font-weight:900; }
  .stat-label { font-size:11px; letter-spacing:3px; color:#8899aa; margin-top:6px; }
  .grid { position:relative; z-index:1; display:grid; grid-template-columns:repeat(auto-fill,minmax(380px,1fr));
    gap:1px; background:rgba(0,255,136,.05); margin:0 40px 40px; }
  .card { background:rgba(2,8,16,.95); padding:20px; border-left:2px solid transparent; transition:.2s; }
  .card:hover { background:rgba(0,255,136,.05); border-left-color:var(--acid); }
  .card.anomalie { border-left-color:var(--red); }
  .card-header { display:flex; justify-content:space-between; margin-bottom:12px; }
  .card-id { font-size:11px; color:#8899aa; }
  .card-time { font-size:11px; color:#8899aa; }
  .card-source { font-size:12px; color:var(--blue); letter-spacing:2px; margin-bottom:8px; }
  .card-objets { font-size:13px; color:var(--acid); margin-bottom:10px; font-weight:bold; }
  .card-analyse { font-size:11px; color:#aabbcc; line-height:1.6; }
  .badge { display:inline-block; padding:2px 8px; border-radius:2px; font-size:10px; letter-spacing:1px; }
  .badge-ok { border:1px solid rgba(0,255,136,.3); color:var(--acid); }
  .badge-alerte { border:1px solid rgba(255,68,102,.5); color:var(--red); background:rgba(255,68,102,.1); }
  .empty { text-align:center; padding:60px; color:#8899aa; grid-column:1/-1; }
  footer { text-align:center; padding:20px; color:#8899aa; font-size:11px; letter-spacing:2px; }
</style>
</head>
<body>
<div class="stars"></div>
<header>
  <div>
    <div style="font-size:11px;color:var(--acid);letter-spacing:4px;margin-bottom:4px">🔭 STATION D'ANALYSE COSMIQUE</div>
    <div class="logo">GALERIE COSMIQUE</div>
    <div style="font-size:11px;color:#8899aa;margin-top:4px">DIRECTEUR : ZAKARIA CHOHRA | 5.78.153.17</div>
  </div>
  <nav class="nav">
    <a href="/">QG</a>
    <a href="/overlord_live">LIVE</a>
    <a href="/galerie">GALERIE</a>
    <a href="/vision">VISION</a>
  </nav>
</header>

<div class="stats">
  <div class="stat">
    <div class="stat-val" style="color:var(--acid)">{{ stats.total }}</div>
    <div class="stat-label">OBSERVATIONS TOTALES</div>
  </div>
  <div class="stat">
    <div class="stat-val" style="color:var(--red)">{{ stats.anomalies }}</div>
    <div class="stat-label">ANOMALIES DÉTECTÉES</div>
  </div>
  <div class="stat">
    <div class="stat-val" style="color:var(--blue)">{{ observations|length }}</div>
    <div class="stat-label">ANALYSES AFFICHÉES</div>
  </div>
</div>

<div class="grid">
  {% if observations %}
    {% for obs in observations %}
    <div class="card {% if obs.anomalie %}anomalie{% endif %}">
      <div class="card-header">
        <span class="card-id">#{{ obs.id }}</span>
        <span class="card-time">{{ obs.timestamp }}</span>
      </div>
      <div class="card-source">{{ obs.source }}</div>
      <div class="card-objets">{{ obs.objets or 'Non classifié' }}</div>
      <div class="card-analyse">{{ obs.analyse }}</div>
      <div style="margin-top:12px">
        {% if obs.anomalie %}
          <span class="badge badge-alerte">⚠ ANOMALIE</span>
        {% else %}
          <span class="badge badge-ok">✓ NORMAL</span>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  {% else %}
    <div class="empty">Aucune observation disponible — l'archive se remplit en continu.</div>
  {% endif %}
</div>

<footer>ASTRO-SCAN © 2026 — ZAKARIA CHOHRA — HILLSBORO STATION</footer>
</body>
</html>
