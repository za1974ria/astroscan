      <iframe id="frame-overlord" class="page-frame" data-src="/overlord_live"></iframe>
      <iframe id="frame-galerie" class="page-frame" data-src="/galerie"></iframe>
      <iframe id="frame-observatoire" class="page-frame" data-src="/observatoire"></iframe>
      <iframe id="frame-vision" class="page-frame" data-src="/vision"></iframe>
