# -*- coding: utf-8 -*-
"""
Module SONDES SPATIALES — agrégation pour /api/sondes.
Retourne voyager1, voyager2, iss, perseverance, curiosity, jwst, hubble, parker.
Utilise curl (subprocess) pour contourner les restrictions réseau.
"""

import os
import re
import json
import subprocess
from datetime import datetime, timezone

STATION = os.environ.get('STATION', '/root/astro_scan')


def _curl_get(url, timeout=15):
    """GET via curl — contourne restrictions urllib."""
    try:
        r = subprocess.run(
            ['curl', '-s', '-L', '--max-time', str(timeout),
             '-H', 'User-Agent: ORBITAL-CHOHRA/1.0', url],
            capture_output=True, text=True, timeout=timeout + 2,
            cwd=STATION,
        )
        return r.stdout
    except Exception:
        return None


def _fetch_voyager_jpl():
    """Voyager 1 & 2 — NASA JPL Horizons (curl)."""
    out = {}
    try:
        now = datetime.now(timezone.utc)
        y, m, d = now.year, now.month, now.day
        for key, target in [('voyager1', '-31'), ('voyager2', '-32')]:
            url = (
                f"https://ssd.jpl.nasa.gov/api/horizons.api?"
                f"format=text&COMMAND='{target}'&OBJ_DATA=YES&MAKE_EPHEM=YES"
                f"&EPHEM_TYPE=VECTORS&CENTER='500@10'"
                f"&START_TIME='{y}-{m:02d}-{d:02d}'&STOP_TIME='{y}-{m:02d}-{d:02d}T23:59'"
                f"&STEP_SIZE='1d'&QUANTITIES='20'"
            )
            raw = _curl_get(url, timeout=20)
            if not raw:
                continue
            dist_au = None
            speed_km_s = None
            m = re.search(r'RG=\s*([\d.]+)', raw)
            if m:
                dist_au = float(m.group(1))
            m2 = re.search(r'RR=\s*([-\d.]+)', raw)
            if m2:
                speed_km_s = abs(float(m2.group(1)) * 1731.46)
            if dist_au is not None:
                out[key] = {
                    'name': 'Voyager 1' if key == 'voyager1' else 'Voyager 2',
                    'distance_au': round(dist_au, 4),
                    'distance_km': round(dist_au * 149597870.7),
                    'speed_kms': round(speed_km_s, 2) if speed_km_s else 17.0,
                    'status': 'En vol',
                    'source': 'NASA JPL Horizons',
                }
        if 'voyager1' not in out:
            days1 = (now - datetime(1977, 9, 5, tzinfo=timezone.utc)).days
            au1 = 17.0 + days1 * 0.000985
            out['voyager1'] = {'name': 'Voyager 1', 'distance_au': round(au1, 2), 'distance_km': round(au1 * 149597870.7), 'speed_kms': 17.0, 'status': 'En vol (approx.)', 'source': 'Calcul'}
        if 'voyager2' not in out:
            days2 = (now - datetime(1977, 8, 20, tzinfo=timezone.utc)).days
            au2 = 14.5 + days2 * 0.000898
            out['voyager2'] = {'name': 'Voyager 2', 'distance_au': round(au2, 2), 'distance_km': round(au2 * 149597870.7), 'speed_kms': 15.4, 'status': 'En vol (approx.)', 'source': 'Calcul'}
    except Exception:
        pass
    return out


def _fetch_iss():
    try:
        from modules.orbit_engine import get_iss_precise
        data = get_iss_precise()
        if 'error' not in data:
            import requests
            crew_r = requests.get('https://api.open-notify.org/astros.json', timeout=5)
            crew = [p['name'] for p in crew_r.json().get('people',[]) if p.get('craft')=='ISS']
            return {
                'iss': {
                    'name': 'ISS',
                    'lat': round(data['lat'], 4),
                    'lon': round(data['lon'], 4),
                    'altitude_km': round(data['alt_km'], 1),
                    'speed_kms': 7.66,
                    'crew_count': len(crew) or 7,
                    'crew': crew,
                    'status': 'En orbite',
                    'source': 'Skyfield/SGP4'
                }
            }
    except Exception:
        pass
    return {'iss': {'name': 'ISS', 'lat': 0, 'lon': 0, 'altitude_km': 408, 'speed_kms': 7.66, 'crew_count': 7, 'crew': [], 'status': 'En orbite', 'source': 'fallback'}}


def _fetch_mars_rovers():
    """Perseverance & Curiosity — NASA Mars Photos API (curl)."""
    out = {}
    nasa_key = os.environ.get('NASA_API_KEY', 'DEMO_KEY')
    for rover in ['perseverance', 'curiosity']:
        url = f"https://api.nasa.gov/mars-photos/api/v1/rovers/{rover}/latest_photos?api_key={nasa_key}&page=1"
        raw = _curl_get(url, timeout=15)
        if not raw:
            out[rover] = {'name': rover.capitalize(), 'status': 'Données indisponibles'}
            continue
        try:
            data = json.loads(raw)
            photos = data.get('latest_photos') or []
            p = photos[0] if photos else {}
            out[rover] = {
                'name': rover.capitalize(),
                'status': 'Actif',
                'sol': p.get('sol'),
                'earth_date': p.get('earth_date'),
                'camera': (p.get('camera') or {}).get('full_name', ''),
                'img_url': p.get('img_src', ''),
            }
        except Exception:
            out[rover] = {'name': rover.capitalize(), 'status': 'Données indisponibles'}
    return out


def _static_sondes():
    """JWST, Hubble, Parker — données statiques."""
    return {
        'jwst': {
            'name': 'James Webb Space Telescope',
            'status': 'L2',
            'position': 'Point de Lagrange L2',
            'mission': 'Infrarouge',
        },
        'hubble': {
            'name': 'Hubble',
            'status': 'LEO',
            'altitude_km': 547,
            'mission': 'Optique / UV',
        },
        'parker': {
            'name': 'Parker Solar Probe',
            'status': 'En vol',
            'mission': 'Vent solaire',
        },
    }


def get_sondes_payload():
    """
    Agrège toutes les sondes pour /api/sondes.
    Clés : voyager1, voyager2, iss, perseverance, curiosity, jwst, hubble, parker, generated_at.
    """
    payload = {}
    payload.update(_fetch_voyager_jpl())
    payload.update(_fetch_iss())
    payload.update(_fetch_mars_rovers())
    payload.update(_static_sondes())
    payload['generated_at'] = datetime.now(timezone.utc).isoformat()
    return payload
