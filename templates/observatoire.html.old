<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OBSERVATOIRE - ORBITAL CHOHRA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/satellite.js@4.1.3/dist/satellite.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
        
        body {
            font-family: 'Orbitron', sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
            color: #00ffff;
        }

        .glow {
            text-shadow: 0 0 10px #00ffff, 0 0 20px #00ffff, 0 0 30px #00ffff;
        }

        .tab-button {
            transition: all 0.3s ease;
            border-bottom: 3px solid transparent;
        }

        .tab-button.active {
            border-bottom-color: #00ffff;
            background: rgba(0, 255, 255, 0.1);
        }

        .tab-button:hover {
            background: rgba(0, 255, 255, 0.05);
        }

        .card {
            background: rgba(26, 31, 58, 0.8);
            border: 1px solid rgba(0, 255, 255, 0.3);
            backdrop-filter: blur(10px);
        }

        .pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        #telescope-canvas {
            background: #000;
            border: 2px solid #00ffff;
        }

        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            animation: twinkle 3s infinite;
        }

        @keyframes twinkle {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        #iss-canvas {
            background: radial-gradient(circle at center, #001a33 0%, #000000 100%);
            border: 2px solid #00ffff;
        }

        .quiz-option {
            transition: all 0.3s;
            cursor: pointer;
        }

        .quiz-option:hover {
            background: rgba(0, 255, 255, 0.2);
            transform: translateX(5px);
        }

        .quiz-option.correct {
            background: rgba(0, 255, 0, 0.3);
            border-color: #00ff00;
        }

        .quiz-option.incorrect {
            background: rgba(255, 0, 0, 0.3);
            border-color: #ff0000;
        }

        .solar-system-container {
            perspective: 1000px;
        }

        .orbit {
            position: absolute;
            border: 1px solid rgba(0, 255, 255, 0.3);
            border-radius: 50%;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
        }

        .planet {
            position: absolute;
            border-radius: 50%;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .planet:hover {
            transform: scale(1.5);
        }

        .chat-message {
            margin: 8px 0;
            padding: 12px;
            border-radius: 8px;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .user-message {
            background: rgba(0, 100, 255, 0.2);
            border-left: 3px solid #0064ff;
            margin-left: 20%;
        }

        .aegis-message {
            background: rgba(0, 255, 255, 0.2);
            border-left: 3px solid #00ffff;
            margin-right: 20%;
        }
    </style>
</head>
<body class="min-h-screen p-4">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-5xl font-black glow mb-2">⚡ OBSERVATOIRE ⚡</h1>
            <p class="text-cyan-300 text-sm">ORBITAL-CHOHRA ASTRONOMICAL CONTROL CENTER</p>
            <div class="flex justify-center gap-4 mt-4">
                <div class="text-xs">
                    <span class="text-gray-400">STATUS:</span>
                    <span class="text-green-400 pulse">● OPERATIONAL</span>
                </div>
                <div class="text-xs">
                    <span class="text-gray-400">LOCATION:</span>
                    <span class="text-cyan-400">TLEMCEN, ALGERIA</span>
                </div>
            </div>
        </div>

        <!-- Tab Navigation -->
        <div class="flex flex-wrap gap-2 mb-6 bg-gray-900/50 p-2 rounded-lg">
            <button onclick="switchTab('telescope')" id="tab-telescope" class="tab-button active flex-1 px-4 py-2 rounded text-sm font-bold">
                🔭 TÉLESCOPE LIVE
            </button>
            <button onclick="switchTab('iss')" id="tab-iss" class="tab-button flex-1 px-4 py-2 rounded text-sm font-bold">
                🛸 ISS TRACKER
            </button>
            <button onclick="switchTab('archive')" id="tab-archive" class="tab-button flex-1 px-4 py-2 rounded text-sm font-bold">
                📡 ARCHIVE STELLAIRE
            </button>
            <button onclick="switchTab('solar')" id="tab-solar" class="tab-button flex-1 px-4 py-2 rounded text-sm font-bold">
                🌍 SYSTÈME SOLAIRE
            </button>
            <button onclick="switchTab('quiz')" id="tab-quiz" class="tab-button flex-1 px-4 py-2 rounded text-sm font-bold">
                🧠 QUIZ
            </button>
            <button onclick="switchTab('aegis')" id="tab-aegis" class="tab-button flex-1 px-4 py-2 rounded text-sm font-bold">
                🤖 AEGIS AI
            </button>
        </div>

        <!-- Tab Content -->
        <div id="content-telescope" class="tab-content">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">🔭 TÉLESCOPE EN DIRECT</h2>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                    <div class="lg:col-span-2">
                        <canvas id="telescope-canvas" width="800" height="600" class="w-full rounded-lg"></canvas>
                        <div class="mt-4 flex gap-2">
                            <button onclick="generateStarField()" class="bg-cyan-600 hover:bg-cyan-700 px-4 py-2 rounded font-bold">
                                🌌 Nouveau Champ
                            </button>
                            <button onclick="toggleTracking()" class="bg-purple-600 hover:bg-purple-700 px-4 py-2 rounded font-bold">
                                📍 Suivi Auto
                            </button>
                            <button onclick="captureImage()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded font-bold">
                                📸 Capturer
                            </button>
                        </div>
                    </div>
                    <div>
                        <div class="card rounded p-4 mb-4">
                            <h3 class="font-bold mb-2">📊 TÉLÉMÉTRIE</h3>
                            <div class="space-y-2 text-sm">
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Ascension Droite:</span>
                                    <span id="ra-value">12h 34m 56s</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Déclinaison:</span>
                                    <span id="dec-value">+45° 12' 34"</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Azimut:</span>
                                    <span id="az-value">180.5°</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Élévation:</span>
                                    <span id="alt-value">45.3°</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Exposition:</span>
                                    <span id="exp-value">30s</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Température:</span>
                                    <span id="temp-value" class="text-red-400">-5.2°C</span>
                                </div>
                            </div>
                        </div>
                        <div class="card rounded p-4">
                            <h3 class="font-bold mb-2">🎯 OBJETS DÉTECTÉS</h3>
                            <div id="detected-objects" class="space-y-1 text-xs">
                                <div class="text-yellow-400">⭐ HD 189733 (Mag: 7.7)</div>
                                <div class="text-blue-400">⭐ Vega (Mag: 0.03)</div>
                                <div class="text-purple-400">🌟 M31 Andromède</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="content-iss" class="tab-content hidden">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">🛸 INTERNATIONAL SPACE STATION TRACKER</h2>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                    <div class="lg:col-span-2">
                        <canvas id="iss-canvas" width="800" height="600" class="w-full rounded-lg"></canvas>
                    </div>
                    <div>
                        <div class="card rounded p-4 mb-4">
                            <h3 class="font-bold mb-2">📍 POSITION ISS</h3>
                            <div class="space-y-2 text-sm">
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Latitude:</span>
                                    <span id="iss-lat">--</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Longitude:</span>
                                    <span id="iss-lon">--</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Altitude:</span>
                                    <span id="iss-alt" class="text-green-400">-- km</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Vitesse:</span>
                                    <span id="iss-velocity" class="text-yellow-400">-- km/s</span>
                                </div>
                            </div>
                        </div>
                        <div class="card rounded p-4">
                            <h3 class="font-bold mb-2">🌍 VISIBILITÉ TLEMCEN</h3>
                            <div class="space-y-2 text-sm">
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Distance:</span>
                                    <span id="iss-distance">-- km</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Élévation:</span>
                                    <span id="iss-elevation">--°</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-400">Passage:</span>
                                    <span id="next-pass" class="text-cyan-400">Calcul...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="content-archive" class="tab-content hidden">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">📡 ARCHIVE STELLAIRE NASA</h2>
                <div class="mb-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                        <div>
                            <label class="block text-sm mb-2">Objet Céleste</label>
                            <input type="text" id="skyview-target" placeholder="M31, NGC 6543..." 
                                   class="w-full bg-gray-900 border border-cyan-500 rounded px-3 py-2">
                        </div>
                        <div>
                            <label class="block text-sm mb-2">Survey</label>
                            <select id="skyview-survey" class="w-full bg-gray-900 border border-cyan-500 rounded px-3 py-2">
                                <option value="DSS">Digitized Sky Survey (DSS)</option>
                                <option value="SDSSr">SDSS Optical</option>
                                <option value="2MASS-J">2MASS Infrared</option>
                                <option value="WISE 3.4">WISE 3.4μm</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-2">Taille (arcmin)</label>
                            <input type="number" id="skyview-size" value="30" min="5" max="300"
                                   class="w-full bg-gray-900 border border-cyan-500 rounded px-3 py-2">
                        </div>
                    </div>
                    <button onclick="fetchSkyView()" class="bg-cyan-600 hover:bg-cyan-700 px-6 py-2 rounded font-bold">
                        🔍 Rechercher dans les Archives
                    </button>
                </div>
                <div id="skyview-result" class="mt-4">
                    <div class="text-center text-gray-400 py-12">
                        Entrez un objet céleste pour rechercher dans les archives NASA SkyView
                    </div>
                </div>
            </div>
        </div>

        <div id="content-solar" class="tab-content hidden">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">🌍 SYSTÈME SOLAIRE</h2>
                <div class="solar-system-container relative" style="height: 600px;">
                    <div id="solar-system" class="relative w-full h-full"></div>
                </div>
                <div id="planet-info" class="card rounded p-4 mt-4">
                    <h3 class="font-bold mb-2">ℹ️ Informations</h3>
                    <p class="text-sm text-gray-400">Survolez une planète pour voir ses informations</p>
                </div>
            </div>
        </div>

        <div id="content-quiz" class="tab-content hidden">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">🧠 QUIZ ASTRONOMIE</h2>
                <div id="quiz-container">
                    <div class="mb-6">
                        <div class="flex justify-between mb-2">
                            <span>Question <span id="question-number">1</span>/10</span>
                            <span>Score: <span id="quiz-score" class="text-green-400 font-bold">0</span></span>
                        </div>
                        <div class="h-2 bg-gray-700 rounded-full">
                            <div id="quiz-progress" class="h-full bg-cyan-500 rounded-full transition-all" style="width: 10%"></div>
                        </div>
                    </div>
                    <div id="quiz-question" class="mb-6">
                        <h3 class="text-xl font-bold mb-4">Chargement...</h3>
                        <div id="quiz-options" class="space-y-3"></div>
                    </div>
                    <div id="quiz-feedback" class="hidden card rounded p-4 mb-4"></div>
                    <button onclick="nextQuestion()" id="next-btn" class="bg-cyan-600 hover:bg-cyan-700 px-6 py-2 rounded font-bold hidden">
                        Question Suivante →
                    </button>
                </div>
            </div>
        </div>

        <div id="content-aegis" class="tab-content hidden">
            <div class="card rounded-lg p-6">
                <h2 class="text-2xl font-bold mb-4 glow">🤖 AEGIS - AI TUTOR</h2>
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
                    <div class="lg:col-span-3">
                        <div id="chat-messages" class="bg-black/50 rounded-lg p-4 h-96 overflow-y-auto mb-4">
                            <div class="aegis-message">
                                <div class="font-bold text-cyan-400 mb-1">AEGIS</div>
                                <div>Bonjour ! Je suis AEGIS, votre tuteur en astronomie. Posez-moi n'importe quelle question sur l'univers, les étoiles, les planètes, ou les phénomènes cosmiques !</div>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <input type="text" id="chat-input" placeholder="Posez votre question..." 
                                   class="flex-1 bg-gray-900 border border-cyan-500 rounded px-4 py-2"
                                   onkeypress="if(event.key==='Enter') sendMessage()">
                            <button onclick="sendMessage()" class="bg-cyan-600 hover:bg-cyan-700 px-6 py-2 rounded font-bold">
                                Envoyer
                            </button>
                        </div>
                    </div>
                    <div>
                        <div class="card rounded p-4">
                            <h3 class="font-bold mb-2">💡 Sujets Suggérés</h3>
                            <div class="space-y-2 text-sm">
                                <button onclick="quickQuestion('Qu\'est-ce qu\'un trou noir?')" 
                                        class="w-full text-left p-2 bg-gray-800 hover:bg-gray-700 rounded">
                                    Trous noirs
                                </button>
                                <button onclick="quickQuestion('Comment se forment les étoiles?')" 
                                        class="w-full text-left p-2 bg-gray-800 hover:bg-gray-700 rounded">
                                    Formation stellaire
                                </button>
                                <button onclick="quickQuestion('Qu\'est-ce que la matière noire?')" 
                                        class="w-full text-left p-2 bg-gray-800 hover:bg-gray-700 rounded">
                                    Matière noire
                                </button>
                                <button onclick="quickQuestion('Comment observer les exoplanètes?')" 
                                        class="w-full text-left p-2 bg-gray-800 hover:bg-gray-700 rounded">
                                    Exoplanètes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Tab Switching
        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-button').forEach(el => el.classList.remove('active'));
            
            document.getElementById('content-' + tabName).classList.remove('hidden');
            document.getElementById('tab-' + tabName).classList.add('active');

            if (tabName === 'telescope') initTelescope();
            if (tabName === 'iss') initISS();
            if (tabName === 'solar') initSolarSystem();
            if (tabName === 'quiz') loadQuiz();
        }

        // TELESCOPE MODULE
        let telescopeCanvas, telescopeCtx;
        let stars = [];
        let tracking = false;

        function initTelescope() {
            telescopeCanvas = document.getElementById('telescope-canvas');
            telescopeCtx = telescopeCanvas.getContext('2d');
            generateStarField();
            updateTelemetry();
        }

        function generateStarField() {
            stars = [];
            telescopeCtx.fillStyle = '#000';
            telescopeCtx.fillRect(0, 0, telescopeCanvas.width, telescopeCanvas.height);

            for (let i = 0; i < 200; i++) {
                const x = Math.random() * telescopeCanvas.width;
                const y = Math.random() * telescopeCanvas.height;
                const size = Math.random() * 2 + 0.5;
                const brightness = Math.random();
                
                stars.push({ x, y, size, brightness });
                
                telescopeCtx.fillStyle = `rgba(255, 255, 255, ${brightness})`;
                telescopeCtx.beginPath();
                telescopeCtx.arc(x, y, size, 0, Math.PI * 2);
                telescopeCtx.fill();
            }

            // Add some nebulae
            for (let i = 0; i < 3; i++) {
                const x = Math.random() * telescopeCanvas.width;
                const y = Math.random() * telescopeCanvas.height;
                const gradient = telescopeCtx.createRadialGradient(x, y, 0, x, y, 50);
                gradient.addColorStop(0, 'rgba(100, 150, 255, 0.3)');
                gradient.addColorStop(1, 'rgba(100, 150, 255, 0)');
                telescopeCtx.fillStyle = gradient;
                telescopeCtx.fillRect(x - 50, y - 50, 100, 100);
            }
        }

        function updateTelemetry() {
            setInterval(() => {
                document.getElementById('ra-value').textContent = 
                    `${Math.floor(Math.random() * 24)}h ${Math.floor(Math.random() * 60)}m ${Math.floor(Math.random() * 60)}s`;
                document.getElementById('az-value').textContent = 
                    (Math.random() * 360).toFixed(1) + '°';
                document.getElementById('temp-value').textContent = 
                    (Math.random() * 10 - 10).toFixed(1) + '°C';
            }, 3000);
        }

        function toggleTracking() {
            tracking = !tracking;
            alert(tracking ? '📍 Suivi automatique activé' : '📍 Suivi automatique désactivé');
        }

        function captureImage() {
            alert('📸 Image capturée ! Sauvegardée dans AEGIS AUTO');
        }

        // ISS TRACKER MODULE
        let issCanvas, issCtx;
        const TLE_LINE1 = '1 25544U 98067A   23001.00000000  .00016717  00000-0  10270-3 0  9005';
        const TLE_LINE2 = '2 25544  51.6442 247.4627 0006703 130.5360 325.0288 15.72125391 14579';

        function initISS() {
            issCanvas = document.getElementById('iss-canvas');
            issCtx = issCanvas.getContext('2d');
            drawEarth();
            updateISSPosition();
            setInterval(updateISSPosition, 5000);
        }

        function drawEarth() {
            issCtx.clearRect(0, 0, issCanvas.width, issCanvas.height);
            
            // Draw Earth
            const centerX = issCanvas.width / 2;
            const centerY = issCanvas.height / 2;
            const radius = 150;
            
            const gradient = issCtx.createRadialGradient(centerX, centerY, radius * 0.5, centerX, centerY, radius);
            gradient.addColorStop(0, '#4a9eff');
            gradient.addColorStop(0.7, '#2563eb');
            gradient.addColorStop(1, '#1e40af');
            
            issCtx.fillStyle = gradient;
            issCtx.beginPath();
            issCtx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            issCtx.fill();

            // Draw continents (simplified)
            issCtx.fillStyle = '#22c55e';
            issCtx.fillRect(centerX - 60, centerY - 40, 40, 30);
            issCtx.fillRect(centerX + 10, centerY - 20, 50, 40);
        }

        function updateISSPosition() {
            if (typeof satellite === 'undefined') return;
            const satrec = satellite.twoline2satrec(TLE_LINE1, TLE_LINE2);
            const now = new Date();
            const positionAndVelocity = satellite.propagate(satrec, now);
            
            if (positionAndVelocity.position) {
                const gmst = satellite.gstime(now);
                const geodeticCoords = satellite.eciToGeodetic(positionAndVelocity.position, gmst);
                
                const lat = satellite.degreesLat(geodeticCoords.latitude);
                const lon = satellite.degreesLong(geodeticCoords.longitude);
                const alt = geodeticCoords.height;
                
                document.getElementById('iss-lat').textContent = lat.toFixed(4) + '°';
                document.getElementById('iss-lon').textContent = lon.toFixed(4) + '°';
                document.getElementById('iss-alt').textContent = alt.toFixed(0) + ' km';
                
                if (positionAndVelocity.velocity) {
                    const velocity = Math.sqrt(
                        Math.pow(positionAndVelocity.velocity.x, 2) +
                        Math.pow(positionAndVelocity.velocity.y, 2) +
                        Math.pow(positionAndVelocity.velocity.z, 2)
                    );
                    document.getElementById('iss-velocity').textContent = velocity.toFixed(2) + ' km/s';
                }

                // Calculate distance from Tlemcen
                const tlemcenLat = 34.8780;
                const tlemcenLon = -1.3150;
                const distance = calculateDistance(lat, lon, tlemcenLat, tlemcenLon);
                document.getElementById('iss-distance').textContent = distance.toFixed(0) + ' km';

                // Draw ISS on canvas
                drawEarth();
                const x = issCanvas.width / 2 + (lon / 180) * (issCanvas.width / 2);
                const y = issCanvas.height / 2 - (lat / 90) * (issCanvas.height / 2);
                
                issCtx.fillStyle = '#ff0000';
                issCtx.beginPath();
                issCtx.arc(x, y, 5, 0, Math.PI * 2);
                issCtx.fill();
                
                issCtx.strokeStyle = '#ff0000';
                issCtx.setLineDash([5, 5]);
                issCtx.beginPath();
                issCtx.arc(x, y, 15, 0, Math.PI * 2);
                issCtx.stroke();
                issCtx.setLineDash([]);

                issCtx.fillStyle = '#ffffff';
                issCtx.font = '10px Orbitron';
                issCtx.fillText('ISS', x + 10, y - 10);
            }
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                     Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                     Math.sin(dLon / 2) * Math.sin(dLon / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return R * c;
        }

        // SKYVIEW MODULE
        async function fetchSkyView() {
            const target = document.getElementById('skyview-target').value;
            const survey = document.getElementById('skyview-survey').value;
            const size = document.getElementById('skyview-size').value;
            
            if (!target) {
                alert('Veuillez entrer un objet céleste');
                return;
            }

            const resultDiv = document.getElementById('skyview-result');
            resultDiv.innerHTML = '<div class="text-center py-8"><div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-cyan-500"></div><p class="mt-2">Recherche dans les archives NASA...</p></div>';

            try {
                const url = `https://skyview.gsfc.nasa.gov/current/cgi/runquery.pl?Position=${encodeURIComponent(target)}&Survey=${survey}&Pixels=${size * 60 / 5}&Return=GIF`;
                
                resultDiv.innerHTML = `
                    <div class="card rounded p-4">
                        <h3 class="font-bold mb-4">Résultat: ${target}</h3>
                        <img src="${url}" alt="${target}" class="w-full rounded border-2 border-cyan-500" onerror="this.parentElement.innerHTML='<p class=text-red-400>Erreur de chargement. Vérifiez le nom de l\'objet.</p>'">
                        <div class="mt-4 text-sm text-gray-400">
                            <p>Survey: ${survey}</p>
                            <p>Taille: ${size} arcmin</p>
                        </div>
                    </div>
                `;
            } catch (error) {
                resultDiv.innerHTML = '<div class="text-red-400">Erreur de connexion aux archives NASA</div>';
            }
        }

        // SOLAR SYSTEM MODULE
        const planets = [
            { name: 'Mercure', distance: 50, size: 4, color: '#8c7853', period: 3, info: 'La plus proche du Soleil' },
            { name: 'Vénus', distance: 80, size: 9, color: '#ffc649', period: 5, info: 'La plus chaude' },
            { name: 'Terre', distance: 110, size: 10, color: '#4a9eff', period: 7, info: 'Notre maison' },
            { name: 'Mars', distance: 140, size: 6, color: '#e27b58', period: 10, info: 'La planète rouge' },
            { name: 'Jupiter', distance: 200, size: 30, color: '#c88b3a', period: 15, info: 'La plus grande' },
            { name: 'Saturne', distance: 260, size: 25, color: '#fad5a5', period: 20, info: 'Avec ses anneaux' },
            { name: 'Uranus', distance: 310, size: 15, color: '#4fd0e0', period: 25, info: 'Géante de glace' },
            { name: 'Neptune', distance: 350, size: 14, color: '#4166f5', period: 30, info: 'La plus lointaine' }
        ];

        function initSolarSystem() {
            const container = document.getElementById('solar-system');
            container.innerHTML = '';

            // Sun
            const sun = document.createElement('div');
            sun.className = 'planet';
            sun.style.cssText = `
                width: 40px; height: 40px;
                background: radial-gradient(circle, #ffed4e 0%, #ff9500 100%);
                left: 50%; top: 50%;
                transform: translate(-50%, -50%);
                box-shadow: 0 0 30px #ffed4e;
            `;
            container.appendChild(sun);

            planets.forEach((planet, index) => {
                // Orbit
                const orbit = document.createElement('div');
                orbit.className = 'orbit';
                orbit.style.cssText = `
                    width: ${planet.distance * 2}px;
                    height: ${planet.distance * 2}px;
                `;
                container.appendChild(orbit);

                // Planet
                const planetEl = document.createElement('div');
                planetEl.className = 'planet';
                planetEl.style.cssText = `
                    width: ${planet.size}px;
                    height: ${planet.size}px;
                    background: ${planet.color};
                    box-shadow: 0 0 10px ${planet.color};
                `;
                planetEl.setAttribute('data-planet', planet.name);
                planetEl.onmouseover = () => showPlanetInfo(planet);

                // Animation
                const angle = (Date.now() / (planet.period * 1000)) % (2 * Math.PI);
                const x = 50 + Math.cos(angle) * planet.distance;
                const y = 50 + Math.sin(angle) * planet.distance;
                planetEl.style.left = `${x}%`;
                planetEl.style.top = `${y}%`;
                planetEl.style.transform = 'translate(-50%, -50%)';

                container.appendChild(planetEl);
            });

            setInterval(() => {
                planets.forEach(planet => {
                    const planetEl = container.querySelector(`[data-planet="${planet.name}"]`);
                    if (!planetEl) return;
                    const angle = (Date.now() / (planet.period * 1000)) % (2 * Math.PI);
                    const x = 50 + Math.cos(angle) * (planet.distance / 7);
                    const y = 50 + Math.sin(angle) * (planet.distance / 7);
                    planetEl.style.left = `${x}%`;
                    planetEl.style.top = `${y}%`;
                });
            }, 50);
        }

        function showPlanetInfo(planet) {
            document.getElementById('planet-info').innerHTML = `
                <h3 class="font-bold mb-2 text-xl">${planet.name}</h3>
                <p class="text-gray-400">${planet.info}</p>
                <p class="text-sm mt-2">Distance relative: ${planet.distance}px</p>
            `;
        }

        // QUIZ MODULE
        const quizQuestions = [
            { question: "Quelle est la galaxie la plus proche de la Voie Lactée?", options: ["Andromède", "Triangulum", "Centaurus A", "Sombrero"], correct: 0, explanation: "Andromède (M31) est notre galaxie voisine la plus proche, à environ 2,5 millions d'années-lumière." },
            { question: "Combien de temps met la lumière du Soleil pour atteindre la Terre?", options: ["8 secondes", "8 minutes", "8 heures", "8 jours"], correct: 1, explanation: "La lumière parcourt les 150 millions de km en environ 8 minutes et 20 secondes." },
            { question: "Quelle est la planète la plus chaude du système solaire?", options: ["Mercure", "Vénus", "Mars", "Jupiter"], correct: 1, explanation: "Vénus, malgré qu'elle soit plus éloignée du Soleil que Mercure, a un effet de serre extrême qui la rend plus chaude." },
            { question: "Qu'est-ce qu'une supernova?", options: ["Une nouvelle étoile", "L'explosion d'une étoile", "Une comète", "Un astéroïde"], correct: 1, explanation: "Une supernova est l'explosion cataclysmique d'une étoile en fin de vie." },
            { question: "Combien y a-t-il de planètes dans notre système solaire?", options: ["7", "8", "9", "10"], correct: 1, explanation: "Il y a 8 planètes depuis que Pluton a été reclassée en planète naine en 2006." },
            { question: "Quelle est la vitesse de la lumière dans le vide?", options: ["300 000 km/s", "150 000 km/s", "450 000 km/s", "600 000 km/s"], correct: 0, explanation: "La vitesse de la lumière est d'environ 299 792 458 m/s, soit ~300 000 km/s." },
            { question: "Qu'est-ce que la matière noire?", options: ["De la poussière spatiale", "Une forme invisible de matière", "Des trous noirs", "De l'antimatière"], correct: 1, explanation: "La matière noire est une forme hypothétique de matière qui ne peut pas être vue directement mais dont on détecte les effets gravitationnels." },
            { question: "Quelle est la plus grande planète du système solaire?", options: ["Saturne", "Jupiter", "Neptune", "Uranus"], correct: 1, explanation: "Jupiter est la plus grande planète, avec un diamètre de 142 984 km." },
            { question: "Qu'est-ce qu'une exoplanète?", options: ["Une planète explosive", "Une planète en dehors de notre système solaire", "Une ancienne planète", "Une planète artificielle"], correct: 1, explanation: "Une exoplanète est une planète qui orbite autour d'une autre étoile que le Soleil." },
            { question: "Quelle est la constellation la plus facilement reconnaissable?", options: ["Orion", "Grande Ourse", "Cassiopée", "Scorpion"], correct: 1, explanation: "La Grande Ourse (ou Big Dipper) est l'une des constellations les plus reconnaissables dans l'hémisphère nord." }
        ];

        let currentQuestion = 0;
        let score = 0;

        function loadQuiz() {
            currentQuestion = 0;
            score = 0;
            document.getElementById('quiz-score').textContent = score;
            showQuestion();
        }

        function showQuestion() {
            if (currentQuestion >= quizQuestions.length) {
                showResults();
                return;
            }

            const q = quizQuestions[currentQuestion];
            document.getElementById('question-number').textContent = currentQuestion + 1;
            document.getElementById('quiz-progress').style.width = ((currentQuestion + 1) / quizQuestions.length * 100) + '%';
            
            document.querySelector('#quiz-question h3').textContent = q.question;
            
            const optionsHtml = q.options.map((option, index) => `
                <div class="quiz-option card rounded p-4 border border-cyan-500/50" onclick="selectAnswer(${index})">
                    ${option}
                </div>
            `).join('');
            
            document.getElementById('quiz-options').innerHTML = optionsHtml;
            document.getElementById('quiz-feedback').classList.add('hidden');
            document.getElementById('next-btn').classList.add('hidden');
        }

        function selectAnswer(selected) {
            const q = quizQuestions[currentQuestion];
            const options = document.querySelectorAll('.quiz-option');
            
            options.forEach((opt, idx) => {
                opt.onclick = null;
                if (idx === q.correct) {
                    opt.classList.add('correct');
                } else if (idx === selected) {
                    opt.classList.add('incorrect');
                }
            });

            const isCorrect = selected === q.correct;
            if (isCorrect) {
                score++;
                document.getElementById('quiz-score').textContent = score;
            }

            const feedback = document.getElementById('quiz-feedback');
            feedback.className = 'card rounded p-4 mb-4 ' + (isCorrect ? 'border-green-500' : 'border-red-500');
            feedback.innerHTML = `
                <div class="font-bold mb-2">${isCorrect ? '✅ Correct!' : '❌ Incorrect'}</div>
                <div class="text-sm">${q.explanation}</div>
            `;
            feedback.classList.remove('hidden');
            
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            currentQuestion++;
            showQuestion();
        }

        function showResults() {
            const percentage = (score / quizQuestions.length * 100).toFixed(0);
            let message = '';
            if (percentage >= 80) message = '🌟 Excellent! Vous êtes un expert!';
            else if (percentage >= 60) message = '👍 Très bien! Bon niveau!';
            else if (percentage >= 40) message = '📚 Pas mal! Continuez à apprendre!';
            else message = '💪 Continuez vos efforts!';

            document.getElementById('quiz-container').innerHTML = `
                <div class="text-center py-12">
                    <h3 class="text-4xl font-bold mb-4">${percentage}%</h3>
                    <p class="text-xl mb-2">${score}/${quizQuestions.length} bonnes réponses</p>
                    <p class="text-2xl mb-6">${message}</p>
                    <button onclick="loadQuiz()" class="bg-cyan-600 hover:bg-cyan-700 px-8 py-3 rounded font-bold">
                        🔄 Recommencer
                    </button>
                </div>
            `;
        }

        // AEGIS AI MODULE
        const aegisResponses = {
            'trou noir': "Un trou noir est une région de l'espace-temps où la gravité est si intense que rien, pas même la lumière, ne peut s'en échapper. Ils se forment généralement suite à l'effondrement d'étoiles massives.",
            'étoile': "Les étoiles sont des sphères de plasma maintenues par leur propre gravité. Elles produisent de l'énergie par fusion nucléaire dans leur cœur.",
            'galaxie': "Une galaxie est un ensemble gravitationnellement lié d'étoiles, de gaz, de poussières et de matière noire. Notre galaxie, la Voie Lactée, contient environ 200 milliards d'étoiles.",
            'planète': "Une planète est un corps céleste en orbite autour d'une étoile, suffisamment massif pour être sphérique mais pas assez pour déclencher la fusion nucléaire.",
            'exoplanète': "Les exoplanètes sont des planètes en orbite autour d'autres étoiles que le Soleil. Nous en avons découvert plus de 5000 à ce jour!",
            'matière noire': "La matière noire est une forme hypothétique de matière qui n'émet pas de lumière mais dont on détecte les effets gravitationnels. Elle représenterait environ 27% de l'univers.",
            'big bang': "Le Big Bang est le modèle cosmologique décrivant l'origine de l'univers il y a environ 13,8 milliards d'années, à partir d'un état extrêmement dense et chaud."
        };

        function sendMessage() {
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            
            if (!message) return;

            addMessage('user', message);
            input.value = '';

            setTimeout(() => {
                const response = getAegisResponse(message);
                addMessage('aegis', response);
            }, 1000);
        }

        function addMessage(sender, text) {
            const messagesDiv = document.getElementById('chat-messages');
            const messageDiv = document.createElement('div');
            messageDiv.className = sender === 'user' ? 'user-message' : 'aegis-message';
            
            messageDiv.innerHTML = `
                <div class="font-bold ${sender === 'user' ? 'text-blue-400' : 'text-cyan-400'} mb-1">
                    ${sender === 'user' ? 'VOUS' : 'AEGIS'}
                </div>
                <div>${text}</div>
            `;
            
            messagesDiv.appendChild(messageDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function getAegisResponse(message) {
            const lowerMessage = message.toLowerCase();
            
            for (const [key, value] of Object.entries(aegisResponses)) {
                if (lowerMessage.includes(key)) {
                    return value;
                }
            }
            
            return "C'est une excellente question ! L'astronomie est un domaine fascinant. Pour des informations plus détaillées, je vous recommande de consulter les archives stellaires ou de préciser votre question.";
        }

        function quickQuestion(question) {
            document.getElementById('chat-input').value = question;
            sendMessage();
        }

        // Initialize on load
        window.onload = function() {
            initTelescope();
        };
    </script>
</body>
</html>
