<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ASTRO-SCAN · ORBITAL-CHOHRA · Portail</title>
<link rel="icon" href="/static/favicon.ico?v=2">
<link rel="shortcut icon" href="/static/favicon.ico?v=2">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --void: #010408;
  --panel: rgba(3,10,20,0.97);
  --border: rgba(0,180,255,0.13);
  --border-bright: rgba(0,212,255,0.4);
  --cyan: #00d4ff;
  --amber: #ff8c00;
  --green: #00ff88;
  --red: #ff3355;
  --text: #7a9ab0;
  --text-bright: #d0e8f0;
  --text-dim: #3a5868;
  --font: 'Orbitron', monospace;
  --mono: 'Share Tech Mono', monospace;
  --sidebar: 220px;
}

*, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }
html, body {
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: var(--void);
  font-family: var(--mono);
}

/* ── STARS ── */
#stars { position:fixed; inset:0; z-index:0; pointer-events:none; }
.star {
  position:absolute; border-radius:50%; background:#fff;
  animation: tw var(--d,4s) ease-in-out infinite;
  animation-delay: var(--dl,0s); opacity:var(--op,.4);
}
@keyframes tw { 0%,100%{opacity:var(--op)} 50%{opacity:calc(var(--op)*.15)} }

/* ── LAYOUT ── */
.shell {
  display: grid;
  grid-template-columns: 220px 1fr;
  grid-template-rows: 48px 1fr;
  width: 100%;
  min-height: 100vh;
}

/* RESPONSIVE MOBILE REEL */
@media (max-width: 900px) {
  body { overflow-x: hidden; }
  .shell, .shell.sync-scale {
    width: 100vw !important;
    min-width: unset !important;
    transform: none !important;
    grid-template-columns: 1fr !important;
  }
  .sidebar {
    position: fixed !important;
    left: -260px;
    top: 0; bottom: 0;
    width: 260px !important;
    z-index: 999;
    transition: left 0.3s ease;
    overflow-y: auto;
    background: #050a0e;
    box-shadow: 4px 0 20px rgba(0,255,136,0.15);
  }
  .sidebar.open { left: 0 !important; }
  .sidebar-overlay { display: block !important; }
  .sidebar-overlay.active { opacity: 1 !important; pointer-events: all !important; }
  .content-area {
    width: 100vw !important;
    min-width: unset !important;
    overflow-x: hidden;
    padding: 0.5rem;
  }
  .hamburger-btn { display: flex !important; }
  .nav-grid, .cards-grid, .grid-2col, .grid-3col {
    grid-template-columns: 1fr !important;
  }
  .topbar, .stats-bar {
    font-size: 0.7rem !important;
    padding: 0.3rem 0.5rem !important;
    flex-wrap: wrap;
    gap: 0.3rem !important;
  }
  body { font-size: 14px !important; }
  h1, h2 { font-size: 1.1rem !important; }
}
/* desktop defaults — NOT inside media query */
.sidebar-overlay { display: none !important; }
.content-area { min-width: 0; overflow: visible; }

.hamburger-btn {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  margin: -8px 0 -8px -8px;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--cyan);
  font-size: 1.2rem;
  border-radius: 6px;
}
.hamburger-btn:hover { background: rgba(0,212,255,0.1); }
.hamburger-btn:focus { outline: none; }

/* ── TOP BAR ── */
.topbar {
  grid-column: 1/-1;
  display: flex; align-items: center; justify-content: space-between;
  height: 40px;
  padding: 0 20px;
  background: rgba(1,4,8,0.99);
  border-bottom: 1px solid var(--border-bright);
  position: relative; z-index: 10;
}
.topbar::after {
  content:'';
  position:absolute; bottom:0; left:0; right:0; height:1px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  opacity:0.5;
}

.brand {
  display:flex; align-items:center; gap:10px;
}
.brand-icon {
  width:28px; height:28px;
}
.brand-icon svg { width:100%; height:100%; }
.brand-name {
  font-family: var(--font);
  font-size: 0.75rem; font-weight:900;
  letter-spacing:0.2em;
  color: var(--cyan);
  text-shadow: 0 0 15px rgba(0,212,255,0.5);
}
.brand-sep { color:var(--text-dim); margin:0 4px; }
.brand-sub { font-size:0.55rem; letter-spacing:0.2em; color:var(--text-dim); }

.topbar-center {
  display:flex; align-items:center; gap:16px;
}
.asc-portail-sync {
  display:flex; align-items:center; gap:8px;
  font-size:0.55rem; letter-spacing:0.12em; color:var(--text-bright);
  padding:4px 10px; border:1px solid var(--border); border-radius:6px;
  flex-shrink:0; max-width:100%; flex-wrap:wrap;
}
.asc-portail-sync-dot {
  width:8px; height:8px; border-radius:50%; background:#666; flex-shrink:0;
}
.asc-portail-sync-dot.live { background:#00ff88; box-shadow:0 0 8px rgba(0,255,136,0.6); }
.asc-portail-sync-dot.demo { background:#ffaa00; }
.asc-portail-sync-dot.off { background:#ff4466; }

.tbar-stat {
  display:flex; align-items:center; gap:6px;
  font-size:0.55rem; letter-spacing:0.15em; color:var(--text-dim);
  text-transform:uppercase;
}
.tbar-dot { width:6px; height:6px; border-radius:50%; }
.tbar-dot.green { background:var(--green); box-shadow:0 0 6px var(--green); animation:pulse 2s infinite; }
.tbar-dot.amber { background:var(--amber); box-shadow:0 0 5px var(--amber); }
.tbar-visits { display:flex; align-items:center; font-family:var(--font); font-size:0.6rem; letter-spacing:0.12em; color:var(--cyan); padding:4px 10px; background:rgba(0,255,136,0.08); border:1px solid rgba(0,212,255,0.3); border-radius:4px; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* Langue FR/EN */
.lang-toggle {
  display: flex; align-items: center; gap: 2px;
  padding: 4px 8px;
  background: rgba(0,212,255,0.05);
  border: 1px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  font-family: var(--font);
  font-size: 0.5rem;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  transition: all 0.2s;
}
.lang-toggle:hover { border-color: var(--cyan); color: var(--cyan); }
.lang-toggle .active { color: var(--cyan); font-weight: 700; }
.lang-toggle span { padding: 0 3px; user-select: none; }
.lang-toggle span:not(.active) { opacity: 0.5; }

.topbar-right {
  display:flex; align-items:center; gap:16px;
}
#top-clock {
  font-family: var(--font);
  font-size:0.7rem; font-weight:600;
  letter-spacing:0.1em;
  color: var(--text-bright);
}
.top-station {
  font-size:0.5rem; letter-spacing:0.15em; color:var(--text-dim); text-transform:uppercase;
}

/* ── SIDEBAR ── */
.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 220px;
  height: 100vh;
  overflow-y: auto;
  overflow-x: hidden;
}

.main-content {
  margin-left: 220px;
}

.sidebar-section {
  padding: 12px 0 4px;
}
.sidebar-label {
  font-size:0.45rem; letter-spacing:0.3em; text-transform:uppercase;
  color:var(--text-dim); padding:0 16px; margin-bottom:6px;
}

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 16px;
  cursor: pointer;
  transition: all 0.2s;
  border-left: 2px solid transparent;
  position: relative;
  user-select: none;
}
.nav-item:hover {
  background: rgba(0,212,255,0.04);
  border-left-color: rgba(0,212,255,0.3);
}
.nav-item.active {
  background: rgba(0,212,255,0.07);
  border-left-color: var(--cyan);
}
.nav-item.active .nav-label { color:var(--cyan); }
.nav-item.active .nav-icon { color:var(--cyan); }

.nav-icon { font-size:0.9rem; width:18px; text-align:center; color:var(--text-dim); transition:color 0.2s; }
.nav-label {
  font-family: var(--font);
  font-size:0.55rem; letter-spacing:0.12em; text-transform:uppercase;
  color:var(--text-dim); transition:color 0.2s; flex:1;
}
.nav-badge {
  font-size:0.45rem; letter-spacing:0.1em;
  padding:1px 6px;
  border:1px solid currentColor;
  text-transform:uppercase;
}
.nav-badge.live { color:var(--green); border-color:rgba(0,255,136,0.4); animation:pulse 2s infinite; }
.nav-badge.new { color:var(--amber); border-color:rgba(255,140,0,0.4); }

.s-divider {
  height:1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 8px 0;
}

/* ── ISS PANEL (sidebar) ── */
.iss-panel {
  margin: 8px 12px;
  padding: 10px;
  background: rgba(0,20,40,0.6);
  border: 1px solid var(--border);
  clip-path: polygon(6px 0%, 100% 0%, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0% 100%, 0% 6px);
}
.iss-panel-title {
  font-family: var(--font);
  font-size: 0.5rem;
  letter-spacing: 0.2em;
  color: var(--cyan);
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}
.iss-globe-wrap {
  width: 100%;
  aspect-ratio: 1;
  max-height: 140px;
  background: rgba(0,10,25,0.8);
  border: 1px solid var(--border);
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  margin-bottom: 8px;
}
#iss-globe {
  width: 100%; height: 100%;
  display: block;
}
.iss-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px 8px;
  font-size: 0.45rem;
  letter-spacing: 0.08em;
  color: var(--text-dim);
}
.iss-stats span:nth-child(odd) { text-transform: uppercase; }
.iss-stats .val { color: var(--text); font-family: var(--font); }
.iss-region {
  margin-top: 6px;
  padding-top: 6px;
  border-top:none !important;
  font-size: 0.45rem;
  color: var(--amber);
  letter-spacing: 0.05em;
  text-align: center;
}

.aegis-status {
  margin:8px 12px;
  padding:8px 10px;
  background: rgba(0,212,255,0.04);
  border:1px solid var(--border);
  clip-path: polygon(4px 0%, 100% 0%, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0% 100%, 0% 4px);
}
.aegis-row { display:flex; justify-content:space-between; align-items:center; }
.aegis-name { font-family:var(--font); font-size:0.5rem; letter-spacing:0.15em; color:var(--cyan); }
.aegis-val { font-size:0.5rem; color:var(--green); letter-spacing:0.08em; }
.aegis-bar { height:2px; background:var(--border); margin-top:6px; overflow:hidden; }
.aegis-bar-fill { height:100%; width:0%; background:var(--cyan); transition:width 0.5s ease; }

/* ── Stats bar (sidebar) ── */
.stats-bar {
  padding: 0 12px;
}
.stats-bar-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 4px;
  border-bottom: 1px solid var(--border);
  font-size: 0.5rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}
.stats-bar-row:last-child { border-bottom: none; }
.stats-bar-row .val {
  font-size: 0.6rem;
  color: var(--cyan);
  font-family: var(--font);
}
.stats-bar-row .val.amber { color: var(--amber); }
.stats-bar-row .val.green { color: var(--green); }

.sidebar-bottom {
  margin-top:auto;
  padding:12px 16px;
  border-top:none !important;
}
.sb-info {
  font-size:0.5rem; letter-spacing:0.1em; color:var(--text-dim);
  line-height:1.6;
}
.sb-val { color:var(--text); }

/* ── CONTENT AREA ── */
.content-area {
  grid-column: 2;
  grid-row: 2;
  position: relative;
  padding: 40px 40px 40px 20px;
  overflow: auto;
  margin-right: 0;
}

#portal-pages {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.page-frame {
  display: none;
  width: 100%;
  height: 100%;
  border: 0;
  background: black;
}

.portal-content {
  padding: 20px;
  max-width: 1400px;
  margin: auto;
}

#splash {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:14px;
  opacity:1; transition:opacity 0.3s;
  padding-top: 5px;
  padding-bottom: 5px;
  max-height: 280px;
  overflow: hidden;
}
.hero-section {
  margin-bottom: 10px;
  min-height: auto;
}
.splash-logo,
.splash-radar,
.hero-radar,
.radar-mask {
  transform: scale(0.55);
  margin-top: -40px;
}
.splash-logo {
  position: relative;
  width: 120px;
  height: auto;
  min-height: 7.5rem;
  margin-bottom: -10px;
}
#splash.hidden { opacity:0; pointer-events:none; }
.splash-logo svg { width:100%; height:100%; }

.splash-rings {
  position:absolute; inset:0;
  animation: srot 20s linear infinite;
}
@keyframes srot { to { transform:rotate(360deg); } }

.splash-title,
#splash h1 {
  font-family:var(--font);
  font-size:34px;
  font-weight:900;
  letter-spacing:5px;
  margin-top: -8px;
  margin-bottom:6px;
  color:var(--cyan);
  text-shadow:0 0 40px rgba(0,212,255,0.6);
  text-align:center;
}
.splash-sub {
  font-size:0.65rem; letter-spacing:0.4em; color:var(--text-dim);
  text-transform:uppercase; text-align:center;
}

.splash-nav {
  display:grid; grid-template-columns: repeat(3, 1fr);
  gap:12px; max-width:640px; width:100%; padding:0 20px;
}
.splash-btn {
  background:rgba(0,212,255,0.05);
  border:1px solid var(--border);
  padding:16px 14px;
  cursor:pointer;
  transition:all 0.25s;
  text-align:center;
  clip-path:polygon(6px 0%,100% 0%,100% calc(100% - 6px),calc(100% - 6px) 100%,0% 100%,0% 6px);
  display:flex; flex-direction:column; align-items:center; gap:8px;
}
.splash-btn:hover {
  background:rgba(0,212,255,0.1);
  border-color:var(--border-bright);
  transform:translateY(-3px);
  box-shadow:0 8px 30px rgba(0,0,0,0.5), 0 0 15px rgba(0,212,255,0.08);
}
.splash-btn-icon { font-size:1.6rem; }
.splash-btn-name {
  font-family: var(--font);
  font-size:0.55rem; letter-spacing:0.15em; color:var(--cyan); text-transform:uppercase;
}
.splash-btn-desc { font-size:0.5rem; color:var(--text-dim); letter-spacing:0.08em; }

/* ── Portal dashboard cards (scientific modules) ── */
.portal-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 10px;
  width: 100%;
  max-width: 1200px;
  margin: auto;
  margin-top: 10px;
}
.portal-cards-grid .card {
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px;
  min-height: 100px;
  transition: all 0.25s;
  text-decoration: none;
  color: inherit;
  display: block;
  clip-path: polygon(6px 0%, 100% 0%, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0% 100%, 0% 6px);
}
.portal-cards-grid .card:hover {
  background: rgba(0, 212, 255, 0.1);
  border-color: var(--border-bright);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.4);
}
.portal-cards-grid .card-title {
  font-family: var(--font);
  font-size: 16px;
  letter-spacing: 0.12em;
  color: var(--cyan);
  text-transform: uppercase;
  margin-bottom: 6px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.2);
  padding-bottom: 6px;
}
.portal-cards-grid .card-desc {
  font-size: 12px;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  line-height: 1.4;
  margin-bottom: 8px;
}
.portal-cards-grid .card-link {
  font-size: 0.45rem;
  letter-spacing: 0.1em;
  color: var(--green);
  text-transform: uppercase;
}

.loading-bar {
  position:absolute; bottom:0; left:0;
  opacity:0.7;
  animation:loadbar 1.2s ease both;
}
@keyframes loadbar { from{width:0} to{width:100%} }

.frame-loader {
  position:absolute; inset:0; z-index:3;
  background:var(--void);
  display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:12px;
  transition:opacity 0.4s;
  pointer-events:none;
}
.frame-loader.done { opacity:0; }
.loader-spin {
  width:32px; height:32px;
  border:2px solid var(--border);
  border-top:none !important;
  border-radius:50%;
  animation:spin 0.8s linear infinite;
}
@keyframes spin { to{transform:rotate(360deg)} }
.loader-text { font-family:var(--font); font-size:0.55rem; letter-spacing:0.2em; color:var(--text-dim); text-transform:uppercase; }

/* ── PWA SYNC (mobile) ── */
.pwa-sync-btn {
  display: none;
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 95;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: rgba(0,255,136,.12);
  border: 1px solid var(--cyan);
  color: var(--cyan);
  font-family: var(--font);
  font-size: 0.5rem;
  letter-spacing: 0.15em;
  cursor: pointer;
  border-radius: 6px;
  box-shadow: 0 4px 20px rgba(0,0,0,.4);
}
.pwa-sync-btn:hover { background: rgba(0,255,136,.2); }
@media (max-width: 900px) { .pwa-sync-btn { display: flex; } }

/* ── Splash layout height fix (priority overrides) ── */
#splash {
  padding-top: 5px !important;
  padding-bottom: 5px !important;
  height: auto !important;
  min-height: 0 !important;
}
.hero-section {
  height: auto !important;
  min-height: 0 !important;
  margin-bottom: 8px !important;
}
.splash-logo,
.splash-radar,
.hero-radar,
.radar-mask {
  transform: scale(0.55) !important;
  margin-top: -45px !important;
}
.splash-title {
  font-size: 32px !important;
  margin-top: -6px !important;
  margin-bottom: 4px !important;
}
.portal-cards-grid {
  margin-top: 6px !important;
}

/* ── Portal workspace layout fix ── */
.main-content,
.workspace,
#workspace,
.portal-content {
  height: auto !important;
  min-height: 0 !important;
  overflow: visible !important;
}
#splash {
  padding-top: 4px !important;
  padding-bottom: 4px !important;
}
.hero-section {
  margin-bottom: 6px !important;
}
.splash-logo {
  transform: scale(0.5) !important;
  margin-top: -50px !important;
}
.splash-title {
  font-size: 30px !important;
  margin-top: -10px !important;
  margin-bottom: 4px !important;
}
.portal-cards-grid {
  margin-top: 6px !important;
  max-width: 1300px !important;
}

/* ── Diagnostic CSS AstroScan (correctifs finaux) ── */
.splash-title {
  font-size: 30px !important;
  margin-top: -10px !important;
  margin-bottom: 4px !important;
}
body,
main,
.workspace,
.portal,
.portal-content {
  height: auto !important;
  min-height: 0 !important;
  overflow: visible !important;
}
.portal-cards-grid {
  width: 100% !important;
  max-width: 1400px !important;
  margin: auto !important;
}
.splash-logo,
.splash-radar,
.hero-radar,
.radar-mask {
  transform: scale(0.55) !important;
  margin-top: -30px !important;
}
#splash {
  padding-top: 4px !important;
  padding-bottom: 4px !important;
}
.hero-section {
  margin-bottom: 6px !important;
}

/* allow radar to appear above splash */
.hero-section {
  position: relative !important;
  overflow: visible !important;
}
/* ensure splash does not clip radar */
#splash {
  overflow: visible !important;
}
/* move radar slightly lower so header does not cut it */
.splash-logo,
.splash-radar,
.hero-radar {
  position: relative !important;
  top: 10px !important;
}
/* ensure header does not hide elements */
.topbar {
  z-index: 5 !important;
}
/* radar above splash */
.splash-logo,
.splash-radar,
.hero-radar {
  z-index: 10 !important;
}

/* give space below header */
.hero-section {
  padding-top: 40px !important;
}
/* ensure splash content stays visible */
#splash {
  margin-top: 10px !important;
}
/* keep radar centered and fully visible */
.splash-logo,
.splash-radar,
.hero-radar {
  top: 20px !important;
}

/* ASTROSCAN PORTAL LAYOUT STABLE (règles uniques, sans conflit) */
#splash {
  position: relative;
  width: 100%;
  margin-top: 20px;
  display: block;
}

.portal-hero {
  display: block;
  text-align: center;
  margin: 20px auto 20px auto;
  margin-bottom: 40px;
}

.portal-hero h1 {
  font-family: var(--font);
  font-size: 34px;
  color: var(--cyan);
  text-shadow: 0 0 30px rgba(0, 212, 255, 0.6);
  margin: 0 0 10px 0;
}

.portal-hero p {
  font-size: 18px;
  color: var(--text);
}

.portal-content{
  padding-top:20px;
}

.portal-cards-grid{
  display:grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap:24px;
  justify-content:center;
  margin-top:20px;
}

.portal-card,
.portal-cards-grid .card {
  position: relative;
  width: 100%;
  height: auto;
  min-height: 100px;
  padding: 14px;
}

.portal-card{
  position:relative;
  margin-top:12px;
  width:100%;
  height:auto;
  min-height:100px;
  box-sizing:border-box;
}

.portal-card::before{
  content:"";
  position:absolute;
  top:-6px;
  left:50%;
  transform:translate(-50%,0);
  width:8px;
  height:8px;
  background:var(--cyan);
  clip-path:polygon(50% 0%,0% 100%,100% 100%);
  opacity:0.9;
  pointer-events:none;
}

.portal-card::after,
.portal-cards-grid .card::after {
  display: none;
}

@media screen and (max-width:900px){
  .portal-card, .portal-cards-grid .card {
    width:auto!important;
    min-width:0!important;
    max-width:100%!important;
    display:flex!important;
    flex-direction:column!important;
  }
}

.radial-target {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 120px;
}

.section-divider,
.portal-line {
  display:none !important;
  border:none !important;
}

hr{
  display:none !important;
}

/* Scrollbar style AstroScan */
::-webkit-scrollbar {
  width: 10px;
}
::-webkit-scrollbar-track {
  background: #020b12;
}
::-webkit-scrollbar-thumb {
  background: #0a2a3a;
  border-radius: 6px;
}
::-webkit-scrollbar-thumb:hover {
  background: #0f3f56;
}

/* Fix ligne bleue */

/* ═══ MOBILE OVERRIDE FINAL ═══ */
@media (max-width: 768px) {
  html, body {
    overflow-x: hidden !important;
    width: 100% !important;
    max-width: 100vw !important;
  }
  .shell, .shell.sync-scale {
    display: block !important;
    width: 100% !important;
    min-width: 100% !important;
    max-width: 100vw !important;
    transform: none !important;
    overflow-x: hidden !important;
  }
  .sidebar {
    display: none !important;
    position: fixed !important;
    left: 0 !important;
    top: 0 !important;
    bottom: 0 !important;
    width: 80vw !important;
    max-width: 18.75rem !important;
    z-index: 9999 !important;
    background: #050a0e !important;
    overflow-y: auto !important;
    box-shadow: 4px 0 30px rgba(0,255,136,0.2) !important;
  }
  .sidebar.open {
    display: block !important;
  }
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9998;
  }
  .sidebar-overlay.open { display: block !important; }
  .content-area {
    width: 100vw !important;
    max-width: 100vw !important;
    min-width: unset !important;
    overflow-x: hidden !important;
    padding: 0.5rem !important;
    margin: 0 !important;
  }
  .hamburger-btn {
    display: flex !important;
    position: fixed !important;
    top: 0.5rem !important;
    left: 0.5rem !important;
    z-index: 10000 !important;
    background: rgba(0,255,136,0.15) !important;
    border: 1px solid rgba(0,255,136,0.4) !important;
    color: #00ff88 !important;
    width: 40px !important;
    height: 40px !important;
    border-radius: 8px !important;
    font-size: 1.2rem !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
  }
  /* Topbar */
  .topbar, .stats-bar, [class*="topbar"], [class*="stats-bar"] {
    padding-left: 3rem !important;
    font-size: 0.65rem !important;
    flex-wrap: wrap !important;
    gap: 0.3rem !important;
    overflow: hidden !important;
  }
  /* Grille cards — 1 colonne */
  .nav-grid, .cards-grid, .modules-grid,
  [class*="grid-"], [class*="-grid"]:not(.portal-cards-grid) {
    grid-template-columns: 1fr !important;
    gap: 0.6rem !important;
  }
  /* 2 colonnes pour les petites cards */
  .grid-3col, .grid-2col {
    grid-template-columns: 1fr 1fr !important;
  }
  /* Texte */
  body { font-size: 13px !important; line-height: 1.4 !important; }
  h1 { font-size: 1rem !important; }
  h2, h3 { font-size: 0.95rem !important; }
  /* Cacher elements non essentiels */
  .sync-btn, .pwa-sync-btn { display: none !important; }
}


/* ═══ GRID MOBILE FIX ═══ */
@media (max-width: 768px) {
  /* Toutes les grilles en 1 colonne */
  .nav-grid, .modules-grid, .cards-grid,
  div[style*="grid-template-columns"]:not(.portal-cards-grid),
  .grid, [class*="grid"]:not(.portal-cards-grid) {
    grid-template-columns: 1fr !important;
    width: 100% !important;
  }
  /* Cards pleine largeur */
  .nav-card, .module-card, .card,
  [class*="card"], [class*="-card"] {
    width: 100% !important;
    min-width: unset !important;
    max-width: 100% !important;
  }
  /* Supprimer espaces vides */
  .content-area > * { margin-bottom: 0.8rem !important; }
  /* Police plus grande */
  .nav-card h3, [class*="card"] h3 { font-size: 0.95rem !important; }
  [class*="card"] p, [class*="card"] div { font-size: 0.8rem !important; }
}

/* ═══ PORTAL GRID MOBILE ═══ */
@media (max-width: 768px) {
  .portal-cards-grid {
    grid-template-columns: 1fr 1fr !important;
    width: 100% !important;
    max-width: 100vw !important;
    padding: 0 !important;
    gap: 6px !important;
  }
  .portal-cards-grid .card {
    width: 100% !important;
    max-width: 100% !important;
    min-width: unset !important;
    min-height: 85px !important;
    padding: 10px 8px !important;
    font-size: 0.72rem !important;
  }
  div[style*="repeat(3"] {
    grid-template-columns: 1fr !important;
  }
  /* Vide en bas - forcer hauteur auto */
  .content-area, .portal-content, main {
    height: auto !important;
    min-height: unset !important;
    overflow-y: auto !important;
  }
  /* TLEMCEN pas HILLSBORO */
  .station-location { content: "TLEMCEN" !important; }
}

@media (max-width: 768px) {
  .splash-nav { display: none !important; }
  .splash-btn { padding: 12px !important; font-size: 0.85rem !important; }
}
</style>

<style id="overflow-fix">
/* ===== PORTAIL MOBILE — supplements existing @media blocks ===== */
@media screen and (max-width: 900px) {

  /* Unlock scroll — global body has overflow:hidden by default */
  html, body {
    overflow-x: hidden !important;
    overflow-y: auto !important;
    height: auto !important;
  }

  /* Shell: block layout, no transform (JS disabled) */
  .shell, .shell.sync-scale {
    display: block !important;
    width: 100% !important;
    min-width: 0 !important;
    max-width: 100vw !important;
    transform: none !important;
    height: auto !important;
    min-height: 100vh !important;
    overflow-x: hidden !important;
  }

  /* Content area: full width, scrollable */
  .content-area {
    width: 100% !important;
    min-width: 0 !important;
    max-width: 100vw !important;
    margin-left: 0 !important;
    overflow-x: hidden !important;
    overflow-y: auto !important;
    height: auto !important;
    max-height: none !important;
    padding: 8px !important;
    padding-top: 60px !important;   /* clear the fixed topbar */
    padding-bottom: 80px !important;
    box-sizing: border-box !important;
  }

  /* Topbar: shift right to clear fixed hamburger button */
  .topbar {
    padding-left: 52px !important;
    height: auto !important;
    min-height: 44px !important;
    flex-wrap: wrap !important;
    gap: 4px !important;
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 100 !important;
  }
  .topbar-center { gap: 4px !important; flex-wrap: wrap !important; max-width: calc(100vw - 140px) !important; overflow: hidden !important; }
  .topbar-right { gap: 4px !important; flex-shrink: 0 !important; }
  .brand-sub { display: none !important; }
  .brand-name { font-size: 0.6rem !important; letter-spacing: 0.1em !important; }
  .tbar-stat { font-size: 0.55rem !important; }
  .asc-portail-sync { font-size: 0.5rem !important; padding: 2px 5px !important; }
  .top-clock, #top-clock { font-size: 0.6rem !important; }
  .top-station { display: none !important; }
  .tbar-visits { font-size: 0.55rem !important; }
  .lang-toggle { font-size: 0.6rem !important; }

  /* Status sync row: below fixed topbar */
  .asc-portail-status-sync-row {
    position: fixed !important;
    top: 44px !important;
    left: 0 !important; right: 0 !important;
    z-index: 99 !important;
    padding: 3px 8px !important;
    font-size: 8px !important;
  }

  /* Notification bell: fixed top-right, above everything */
  #astro-notif-bell {
    position: fixed !important;
    top: 8px !important;
    right: 10px !important;
    z-index: 1002 !important;
    margin: 0 !important;
  }
  #astro-notif-bell-btn { width: 30px !important; height: 30px !important; font-size: 14px !important; }
  #astro-notif-dropdown {
    position: fixed !important;
    top: 50px !important;
    right: 8px !important;
    left: 8px !important;
    width: auto !important;
    max-height: 70vh !important;
    overflow-y: auto !important;
    z-index: 1001 !important;
  }

  /* Portal cards — 2 columns on mobile, land directly on cards */
  .portal-cards-grid {
    grid-template-columns: 1fr 1fr !important;
    gap: 6px !important;
    overflow: visible !important;
    margin-top: 0 !important;
    padding: 0 !important;
  }
  .portal-cards-grid .card, .portal-card {
    min-height: 85px !important;
    height: auto !important;
    width: auto !important;
    padding: 10px 8px !important;
    font-size: 0.72rem !important;
    clip-path: none !important;
    margin-bottom: 0 !important;
  }
  .portal-cards-grid .card-title { font-size: 0.65rem !important; letter-spacing: 0.05em !important; }
  .portal-cards-grid .card-desc { font-size: 0.6rem !important; display: -webkit-box !important; -webkit-line-clamp: 2 !important; -webkit-box-orient: vertical !important; overflow: hidden !important; }
  .portal-cards-grid .card-link { font-size: 0.55rem !important; }

  /* Splash: hide logo/hero/nav-buttons on mobile — show only the cards grid */
  .splash-logo { display: none !important; }
  .splash-nav { display: none !important; }
  .portal-hero { display: none !important; }
  .splash-sub { display: none !important; }

  /* Hide director card on mobile */
  .director-card, #director-card,
  #home-screen > div:nth-child(1),
  #home-screen > div:nth-child(2) { display: none !important; }

  /* Hide station text */
  .splash-sub, [class*="station"], .asc-station-line { display: none !important; }

  /* All other grids */
  .nav-grid, .cards-grid, .grid-2col, .grid-3col, .info-grid {
    grid-template-columns: 1fr !important;
    overflow: visible !important;
  }

  /* Cards */
  .card, .widget, .box { width: 100% !important; box-sizing: border-box !important; }

  /* Images */
  img { max-width: 100% !important; height: auto !important; }

  /* Tables */
  table { font-size: 9px !important; width: 100% !important; }
  td, th { padding: 4px 3px !important; font-size: 9px !important; }

  /* Inputs */
  input[type="text"], input[type="search"], select, textarea {
    width: 100% !important; font-size: 14px !important; min-height: 36px !important; box-sizing: border-box !important;
  }

  /* iframes / canvas */
  iframe { width: 100% !important; height: 220px !important; }
  canvas { max-width: 100% !important; height: auto !important; }

  /* AEGIS chat widget */
  #aegis-chat-window {
    width: calc(100vw - 16px) !important;
    right: 8px !important;
    left: 8px !important;
    bottom: 68px !important;
    height: 60vh !important;
  }
  #aegis-fab { bottom: 10px !important; right: 10px !important; }

  /* Text */
  h1 { font-size: 1.1rem !important; }
  h2 { font-size: 1rem !important; }
  h3 { font-size: 0.9rem !important; }
  h4 { font-size: 0.8rem !important; }

  /* Performance: limit stars */
  .star:nth-child(n+80) { display: none !important; }
}

/* Very small phones */
@media screen and (max-width: 380px) {
  .topbar-center { display: none !important; }
  .splash-nav { grid-template-columns: 1fr !important; }
  .portal-cards-grid .card { font-size: 0.75rem !important; }
}
</style>
