# AstroScan — Variables d'environnement
# Copier vers .env et remplir les valeurs
# chmod 600 .env  (ne jamais committer .env)

# ── Flask SECRET_KEY (REQUIRED in production, ≥ 16 chars) ────────────────────
# Generate a strong random key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# In production, app/__init__.py raises RuntimeError if SECRET_KEY is missing
# or < 16 chars (PASS 26.A enforcement).
SECRET_KEY=replace_me_with_a_64_char_hex_token

# ── Paths ────────────────────────────────────────────────────────────────────
# Repository root (used by background threads to locate data/)
STATION=/root/astro_scan
# SQLite archive used by analytics, observations, visitor_log
DB_PATH=/root/astro_scan/data/archive_stellaire.db

# ── APIs IA ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_BACKUP=your_gemini_backup_key_here
GROQ_API_KEY=your_groq_key_here
XAI_API_KEY=your_xai_key_here
XAI_MODEL=grok-3
XAI_CHAT_COMPLETIONS_URL=https://api.x.ai/v1/chat/completions

# ── NASA ─────────────────────────────────────────────────────────────────────
NASA_API_KEY=your_nasa_key_or_DEMO_KEY

# ── Cartographie ─────────────────────────────────────────────────────────────
CESIUM_TOKEN=your_cesium_ion_token_here
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ── Satellites ───────────────────────────────────────────────────────────────
N2YO_API_KEY=your_n2yo_key_here

# ── Contrôle accès ───────────────────────────────────────────────────────────
# IPs propriétaire (exclure des stats visiteurs), séparées par virgule
ASTROSCAN_OWNER_IPS=1.2.3.4,5.6.7.8
ASTROSCAN_MY_IP=1.2.3.4

# ── Admin API ────────────────────────────────────────────────────────────────
# Token utilisé par les décorateurs require_admin (PASS 28.SEC).
# Header attendu : "X-Admin-Token: <token>" (ou Authorization: Bearer <token>).
# Fail-closed : si ADMIN_TOKEN ET ASTROSCAN_ADMIN_TOKEN sont vides, TOUS les
# endpoints admin renvoient 503. Génère un token solide :
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
# Compat legacy (utilisé en fallback si ADMIN_TOKEN est vide).
ASTROSCAN_ADMIN_TOKEN=your_admin_bearer_token_here

# ── Rate-limit IA (PASS 28.SEC) ──────────────────────────────────────────────
# Anti-drainage financier sur les endpoints qui appellent Claude/Gemini/Groq/Grok.
# Implémenté en mémoire process-local (app/services/security.py::rate_limit_ip),
# fenêtre glissante 60s, clé (endpoint, IP).
# IMPORTANT : non distribué — chaque worker gunicorn a son compteur.
# Avec 4 workers, la limite effective ≈ 4 × valeur déclarée. Migrer vers Redis
# si un rate-limit strict global devient nécessaire.
# Limites actuelles (codées en dur dans les blueprints) :
#   /api/chat                  : 10/min/IP
#   /api/aegis/chat            :  8/min/IP
#   /api/oracle-cosmique       :  3/min/IP   (Claude streaming)
#   /api/guide-stellaire       :  2/min/IP   (Claude OPUS)
#   /api/translate             : 20/min/IP
#   /api/astro/explain         : 10/min/IP
#   /api/science/analyze-image :  5/min/IP   (Claude vision)
#   /api/sky-camera/analyze    :  5/min/IP   (Claude vision)

# ── Flask / infra ────────────────────────────────────────────────────────────
FLASK_ENV=production
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# ── OpenSky / flight-radar ───────────────────────────────────────────────────
# OAuth2 (recommandé) ou laisser vide pour mode anonyme (~100 req/j).
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
# Contournement ban IP / 429 : proxy ScrapingBee (rotation IP).
# SCRAPINGBEE_API_KEY=   # ou SCRAPINGBEE_KEY
# OPENSKY_USE_SCRAPINGBEE=0   # 1 = tout via ScrapingBee ; 0 = direct puis auto après 5×429
