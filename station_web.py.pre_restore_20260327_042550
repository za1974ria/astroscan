#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os, time, sqlite3, json
from datetime import datetime
from flask import Flask, jsonify, render_template

app = Flask(__name__)
START_TIME = time.time()
DB_PATH = '/root/astro_scan/astro_scan.db'
IMG_DIR = '/root/astro_scan/static/captures' # Vérifiez ce chemin Chef

def _get_stats():
    """Récupère les stats réelles pour supprimer le mode 'degraded'."""
    try:
        conn = sqlite3.connect(DB_PATH)
        c = conn.execute("SELECT count FROM visits WHERE id=1").fetchone()
        v_count = c[0] if c else 0
        # Scan des images réelles
        img_count = len([f for f in os.listdir(IMG_DIR) if f.endswith(('.jpg', '.png'))]) if os.path.exists(IMG_DIR) else 0
        conn.close()
        return v_count, img_count
    except: return 0, 0

@app.route("/", methods=["GET"])
def home(): return render_template("portail.html"), 200

@app.route("/portail", methods=["GET"])
def portail(): return render_template("research_dashboard.html"), 200

@app.route("/status", methods=["GET"])
@app.route("/health", methods=["GET"])
def full_status():
    v_count, img_count = _get_stats()
    return jsonify({
        "app_status": "OPERATIONAL" if img_count > 0 else "NOMINAL",
        "collector_status": {"image_collector": "active", "skyview_sync": "ok"},
        "image_count": img_count,
        "tle_status": "cached",
        "uptime_seconds": int(time.time() - START_TIME),
        "version": "1.1"
    })

@app.route('/api/visits', methods=['GET'])
@app.route('/api/visits/count', methods=['GET'])
@app.route('/api/visitors/stats', methods=['GET'])
def api_visits():
    v_count, _ = _get_stats()
    return jsonify({"count": v_count, "status": "OK"})

@app.route('/api/aegis/status', methods=['GET'])
def api_aegis():
    return jsonify({"gemini_configured": True, "groq_ok": True, "ok": True})

@app.route('/api/shield', methods=['GET'])
def shield():
    st = 'SCAN NOCTURNE' if (datetime.now().hour >= 20 or datetime.now().hour < 6) else 'PROTECTION ACTIVE'
    return jsonify({"ok": True, "status": st})

if __name__ == "__main__":
    app.run(host="127.0.0.1", port=5003)