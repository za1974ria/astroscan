</div>

<script>
(function() {
  'use strict';

  var API_INTERVALS = {
    iss: 15000,
    voyager: 20000,
    weather: 30000,
    latest: 30000,
    title: 30000,
    sdr: 20000,
    systemHealth: 15000,
    diagnostics: 15000,
    visits: 60000
  };

  // ── i18n FR/EN ──
  var T = {
    fr: {
      aegis_active: 'AEGIS ACTIF',
      web_online: 'WEB EN LIGNE',
      nasa_sync: 'NASA SYNC',
      nav_label: 'Navigation',
      nav_home: 'Accueil',
      nav_dashboard: 'Dashboard QG',
      nav_overlord: 'Overlord En Direct',
      nav_galerie: 'Archive Stellaire',
      nav_observatoire: 'Observatoire',
      nav_vision: 'Vision 2026',
      iss_lat: 'Lat',
      iss_lon: 'Lon',
      iss_crew: 'Équipage',
      sdr_next: 'Prochain',
      sdr_countdown: 'Décompte',
      stats_live: 'Stats en Direct',
      obs: 'Observations',
      anomalies: 'Anomalies',
      sources: 'Sources',
      aegis_actif: 'ACTIF',
      req_jour: 'REQ/JOUR',
      splash_sub: "Station d'Analyse Astronomique · Tlemcen · En Ligne",
      splash_dash_desc: "Vue d'ensemble en direct",
      splash_overlord_desc: 'Centre de contrôle',
      splash_galerie_desc: 'Catalogue observations',
      splash_obs_desc: 'Télescopes mondiaux',
      splash_vision_desc: 'Roadmap du projet',
      open_direct: 'Ouvrir Direct',
      open_direct_desc: 'Onglet séparé',
      loading: 'Chargement...'
    },
    en: {
      aegis_active: 'AEGIS ACTIVE',
      web_online: 'WEB ONLINE',
      nasa_sync: 'NASA SYNC',
      nav_label: 'Navigation',
      nav_home: 'Home',
      nav_dashboard: 'HQ Dashboard',
      nav_overlord: 'Overlord Live',
      nav_galerie: 'Stellar Archive',
      nav_observatoire: 'Observatory',
      nav_vision: 'Vision 2026',
      iss_lat: 'Lat',
      iss_lon: 'Lon',
      iss_crew: 'Crew',
      sdr_next: 'Next',
      sdr_countdown: 'Countdown',
      stats_live: 'Live Stats',
      obs: 'Observations',
      anomalies: 'Anomalies',
      sources: 'Sources',
      aegis_actif: 'ACTIVE',
      req_jour: 'REQ/DAY',
      splash_sub: 'Astronomical Analysis Station · Tlemcen · Online',
      splash_dash_desc: 'Live overview',
      splash_overlord_desc: 'Control center',
      splash_galerie_desc: 'Observations catalog',
      splash_obs_desc: 'World telescopes',
      splash_vision_desc: 'Project roadmap',
      open_direct: 'Open Direct',
      open_direct_desc: 'New tab',
      loading: 'Loading...'
    }
  };

  var currentLang = localStorage.getItem('portail_lang') || 'fr';

  function applyLang(lang) {
    currentLang = lang;
    localStorage.setItem('portail_lang', lang);
    document.querySelectorAll('[data-i18n]').forEach(function(el) {
      var key = el.getAttribute('data-i18n');
      if (T[lang] && T[lang][key] !== undefined) el.textContent = T[lang][key];
    });
    document.querySelectorAll('#lang-toggle span').forEach(function(s) {
      s.classList.toggle('active', s.getAttribute('data-lang') === lang);
    });
  }

  document.getElementById('lang-toggle').addEventListener('click', function() {
    currentLang = currentLang === 'fr' ? 'en' : 'fr';
    applyLang(currentLang);
  });
  applyLang(currentLang);

  /* mobile: no transform scaling */

  // ── Hamburger (mobile): sidebar slide-in = même layout PC ──
  (function() {
    var sidebar = document.querySelector('.sidebar');
    var overlay = document.getElementById('sidebar-overlay');
    var btn = document.getElementById('hamburger-btn');
    if (!sidebar || !overlay || !btn) return;
    // Ensure sidebar is hidden on mobile at init
    if (window.innerWidth <= 900) {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    }
    function open() { sidebar.classList.add('open'); overlay.classList.add('open'); overlay.setAttribute('aria-hidden', 'false'); }
    function close() { sidebar.classList.remove('open'); overlay.classList.remove('open'); overlay.setAttribute('aria-hidden', 'true'); }
    function toggle() { if (sidebar.classList.contains('open')) close(); else open(); }
    btn.addEventListener('click', toggle);
    overlay.addEventListener('click', close);
    document.querySelectorAll('.sidebar .nav-item').forEach(function(item) {
      item.addEventListener('click', function() { if (window.innerWidth <= 900) close(); });
    });
  })();

  // ── Stars ──
  (function(){
    var s = document.getElementById('stars');
    for (var i = 0; i < 120; i++) {
      var el = document.createElement('div');
      el.className = 'star';
      var sz = Math.random() < 0.88 ? Math.random() * 0.9 + 0.2 : Math.random() * 1.5 + 0.6;
      el.style.cssText = 'left:' + Math.random() * 100 + '%;top:' + Math.random() * 100 + '%;width:' + sz + 'px;height:' + sz + 'px;--d:' + (3 + Math.random() * 5) + 's;--dl:' + (-Math.random() * 5) + 's;--op:' + (0.1 + Math.random() * 0.4);
      s.appendChild(el);
    }
  })();

  // ── Clock ──
  function tick() {
    var n = new Date();
    document.getElementById('top-clock').textContent =
      [n.getUTCHours(), n.getUTCMinutes(), n.getUTCSeconds()].map(function(x) { return String(x).padStart(2, '0'); }).join(':') + ' UTC';
  }
  setInterval(tick, 1000);
  tick();

  // ── ISS Globe canvas (animé: anneau orbital tournant + mascotte ISS) ──
  var issData = { lat: 0, lon: 0, alt: 408, speed: 27600, region: '—', crew: 7 };
  var orbitAngle = 0;
  var issPulse = 0;

  function drawIssGlobe() {
    var c = document.getElementById('iss-globe');
    if (!c) return;
    var ctx = c.getContext('2d');
    var w = c.width;
    var h = c.height;
    var cx = w / 2;
    var cy = h / 2;
    var r = Math.min(w, h) / 2 - 2;

    ctx.clearRect(0, 0, w, h);

    // Cercle fond (océan)
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(0, 20, 45, 0.95)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(0, 212, 255, 0.25)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Anneau orbital animé (tourne en continu)
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(orbitAngle);
    ctx.strokeStyle = 'rgba(0, 212, 255, 0.35)';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 6]);
    ctx.beginPath();
    ctx.ellipse(0, 0, r * 0.92, r * 0.38, 0, 0, Math.PI * 2);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();

    // Grille (méridiens / parallèles)
    ctx.strokeStyle = 'rgba(0, 212, 255, 0.08)';
    ctx.lineWidth = 0.5;
    for (var i = -2; i <= 2; i++) {
      ctx.beginPath();
      ctx.ellipse(cx, cy, r, r * 0.4, 0, 0, Math.PI * 2);
      ctx.stroke();
    }
    for (var j = 0; j < 6; j++) {
      var a = (j / 6) * Math.PI * 2;
      ctx.beginPath();
      ctx.moveTo(cx + r * Math.cos(a), cy + r * 0.4 * Math.sin(a));
      ctx.lineTo(cx - r * Math.cos(a), cy - r * 0.4 * Math.sin(a));
      ctx.stroke();
    }

    // Position ISS: lon → x, lat → y (projection simple)
    var lat = (issData.lat * Math.PI) / 180;
    var lon = (issData.lon * Math.PI) / 180;
    var x = cx + r * Math.cos(lat) * Math.sin(lon);
    var y = cy - r * 0.4 * Math.sin(lat);

    if (x * x + (y - cy) * (y - cy) <= r * r) {
      // Halo pulsant autour de la mascotte ISS
      ctx.save();
      ctx.translate(x, y);
      var haloR = 9 + Math.sin(issPulse) * 2;
      ctx.beginPath();
      ctx.arc(0, 0, haloR, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(0,212,255,0.4)';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Corps de l'ISS (module central)
      ctx.rotate(orbitAngle);
      ctx.fillStyle = '#0b1b2a';
      ctx.strokeStyle = '#00d4ff';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.roundRect(-4, -2.2, 8, 4.4, 1.2);
      ctx.fill();
      ctx.stroke();

      // Panneaux solaires bleus
      ctx.fillStyle = '#2aa9ff';
      ctx.beginPath();
      ctx.roundRect(-11, -1.6, 5, 3.2, 1);
      ctx.roundRect(6, -1.6, 5, 3.2, 1);
      ctx.fill();

      // Radiateurs clairs
      ctx.strokeStyle = 'rgba(220,245,255,0.8)';
      ctx.lineWidth = 0.6;
      ctx.beginPath();
      ctx.moveTo(-3, -1);
      ctx.lineTo(3, -1);
      ctx.moveTo(-3, 1);
      ctx.lineTo(3, 1);
      ctx.stroke();

      // Petit nez/bloc avant pour rappeler la forme réelle
      ctx.beginPath();
      ctx.moveTo(4, 0);
      ctx.lineTo(6, -1);
      ctx.lineTo(6, 1);
      ctx.closePath();
      ctx.fillStyle = '#00d4ff';
      ctx.fill();

      ctx.restore();
    }

    orbitAngle += 0.004;
    issPulse += 0.04;
    if (orbitAngle > Math.PI * 2) orbitAngle -= Math.PI * 2;
  }

  function issAnimationLoop() {
    drawIssGlobe();
    requestAnimationFrame(issAnimationLoop);
  }
  requestAnimationFrame(issAnimationLoop);

  function fetchIss() {
    fetch('/api/iss').then(function(r) { return r.ok ? r.json() : null; }).then(function(d) {
      if (!d) return;
      issData.lat = d.lat;
      issData.lon = d.lon;
      issData.alt = d.alt;
      issData.speed = d.speed;
      issData.region = d.region || '—';
      issData.crew = typeof d.crew === 'number' ? d.crew : 7;
      var el;
      if ((el = document.getElementById('iss-lat'))) el.textContent = d.lat.toFixed(1) + '°';
      if ((el = document.getElementById('iss-lon'))) el.textContent = d.lon.toFixed(1) + '°';
      if ((el = document.getElementById('iss-alt'))) el.textContent = d.alt;
      if ((el = document.getElementById('iss-speed'))) el.textContent = (d.speed / 1000).toFixed(1) + ' km/s';
      if ((el = document.getElementById('iss-region'))) el.textContent = d.region || '—';
      if ((el = document.getElementById('iss-crew'))) el.textContent = issData.crew;
    }).catch(function() {});
  }
  fetchIss();
  setInterval(fetchIss, API_INTERVALS.iss);

  // Compteur visites (format "000 123")
  function fmtVisits(n){var s=String(Math.max(0,n));var p=('000000'+s).slice(-6);return p.slice(0,3)+' '+p.slice(3);}
  function loadVisitsPortail(){fetch('/api/visits').then(function(r){return r.ok?r.json():null;}).then(function(d){var el=document.getElementById('tbar-visits-val');if(el&&d)el.textContent=fmtVisits(d.count||0);}).catch(function(){});}
  loadVisitsPortail();
  setInterval(loadVisitsPortail, API_INTERVALS.visits);

  // ── Widget Radio SDR (countdown, fréquence, indicateur capture) ──
  var radioPassesCache = { passes: [] };
  function formatCountdown(aos) {
    if (!aos || aos <= 0) return '—';
    var now = Date.now() / 1000;
    if (aos <= now) return (currentLang === 'fr' ? 'En cours' : 'Live');
    var s = Math.floor(aos - now);
    var m = Math.floor(s / 60), h = Math.floor(m / 60);
    if (h > 0) return h + 'h ' + (m % 60) + 'm';
    if (m > 0) return m + 'm ' + (s % 60) + 's';
    return s + 's';
  }
  function updateRadioWidget() {
    var next = radioPassesCache.passes.filter(function(p) { return p.aos > Date.now() / 1000; })[0] || radioPassesCache.passes[0];
    var el;
    if ((el = document.getElementById('pw-countdown'))) el.textContent = next ? formatCountdown(next.aos) : '—';
    if (next && (el = document.getElementById('pw-next-sat'))) el.textContent = next.sat || '—';
    if (next && (el = document.getElementById('pw-freq'))) el.textContent = next.freq || '—';
  }
  function fetchRadioWidget() {
    fetch('/api/sdr/passes').then(function(r) { return r.ok ? r.json() : null; }).then(function(d) {
      if (d && d.passes) radioPassesCache.passes = d.passes;
      updateRadioWidget();
    }).catch(function() {});
    fetch('/api/sdr/status').then(function(r) { return r.ok ? r.json() : null; }).then(function(d) {
      var ind = document.getElementById('pw-capture-indicator');
      if (!ind) return;
      var status = (d && d.status || '').toLowerCase();
      if (status.indexOf('captur') !== -1 || status === 'recording') {
        ind.innerHTML = '🔴 ' + (currentLang === 'fr' ? 'Capture en cours' : 'Recording');
        ind.style.color = 'var(--red)';
      } else {
        ind.textContent = 'Tlemcen, DZ';
        ind.style.color = 'var(--amber)';
      }
    }).catch(function() {});
  }
  fetchRadioWidget();
  setInterval(fetchRadioWidget, API_INTERVALS.sdr);
  setInterval(updateRadioWidget, 1000);

  function loadSidebarHubble(){
    fetch('/api/hubble/images')
      .then(function(r){ return r.json(); })
      .then(function(imgs){
        var el = document.getElementById('sidebar-hubble');
        if(!el) return;
        if(!imgs || !imgs.length){ el.innerHTML='<div style="color:#ff4444;font-size:9px;padding:4px">Indisponible</div>'; return; }
        var isMobile = window.innerWidth < 768;
        var html = '<div style="display:grid;grid-template-columns:' + (isMobile ? '1fr 1fr' : '1fr 1fr 1fr') + ';gap:3px">';
        for(var i=0;i<Math.min(4,imgs.length);i++){
          var img = imgs[i];
          var url = (img.url||'').replace(/'/g,"\\'");
          html += '<div style="border:1px solid #00ff8833;border-radius:3px;overflow:hidden;cursor:pointer" onclick="window.open(\''+url+'\',\'_blank\')">';
          if(img.url) html += '<img src="'+img.url+'" style="width:100%;height:55px;object-fit:cover" onerror="this.style.display=\'none\'">';
          html += '<div class="hubble-sidebar-title" style="font-size:7px;color:#00ff88;padding:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">'+(img.title||'')+'</div>';
          html += '</div>';
        }
        html += '</div>';
        el.innerHTML = html;
      })
      .catch(function(){
        var el = document.getElementById('sidebar-hubble');
        if(el) el.innerHTML='<div style="color:#ff4444;font-size:9px;padding:4px">Erreur fetch</div>';
      });
  }
  setTimeout(loadSidebarHubble, 2000);
  setInterval(loadSidebarHubble, 3600000);

  // ── Navigation & lazy iframes ──
  var PAGES = {
    dashboard:    { frame: 'frame-dashboard',    label: 'Dashboard QG' },
    overlord:     { frame: 'frame-overlord',     label: 'Overlord Live' },
    galerie:      { frame: 'frame-galerie',      label: 'Archive Stellaire' },
    observatoire: { frame: 'frame-observatoire', label: 'Observatoire Mondial' },
    vision:       { frame: 'frame-vision',       label: 'Vision 2026' },
    'mission-control': { frame: 'frame-mission-control', label: 'Contrôle Mission' },
    'orbital-map': { frame: 'frame-orbital-map', label: 'Carte Orbitale' }
  };
  var current = 'home';
  var loaded = {};

  function navigate(page) {
    console.log("NAVIGATE ->", page);
    document.querySelectorAll(".nav-item").forEach(el => {
      el.classList.remove("active");
    });
    var nav = document.querySelector("#nav-" + page);
    if (nav) nav.classList.add("active");
    var homeScreen = document.getElementById("home-screen");
    if (page === "home") {
      if (homeScreen) homeScreen.style.display = "";
      document.querySelectorAll(".page-frame").forEach(frame => { frame.style.display = "none"; });
      return;
    }
    if (homeScreen) homeScreen.style.display = "none";
    document.querySelectorAll(".page-frame").forEach(frame => {
      frame.style.display = "none";
    });
    var frame = document.getElementById("frame-" + page);
    if (!frame) {
      console.error("FRAME NOT FOUND:", page);
      return;
    }
    if (!frame.src || frame.src === "about:blank") {
      frame.src = frame.dataset.src;
    }
    frame.style.display = "block";
  }
  window.navigate = navigate;

  // ── Stats ──
  function loadStats() {
    fetch('/api/latest').then(function(r) {
      if (!r.ok) return null;
      return r.json();
    }).then(function(d) {
      if (!d) return;
      var total = (d.stats && d.stats.total !== undefined) ? d.stats.total : d.total;
      var anom = (d.stats && d.stats.anomalies !== undefined) ? d.stats.anomalies : d.anomalies;
      var src = (d.stats && d.stats.sources !== undefined) ? d.stats.sources : d.sources;
      var reqJ = (d.stats && d.stats.req_jour !== undefined) ? d.stats.req_jour : d.req_jour;
      var el;
      if (total !== undefined && (el = document.getElementById('sb-total'))) el.textContent = total;
      if (anom !== undefined && (el = document.getElementById('sb-anomalies'))) el.textContent = anom;
      if (src !== undefined && (el = document.getElementById('sb-sources'))) el.textContent = src;
      if (reqJ !== undefined && (el = document.getElementById('sb-req'))) el.textContent = reqJ + ' / 1400';
      var bar = document.getElementById('sb-bar');
      if (bar && reqJ !== undefined) bar.style.width = Math.min(100, (reqJ / 1400) * 100) + '%';
    }).catch(function() {});
  }
  loadStats();
  setInterval(loadStats, API_INTERVALS.latest);

  // ── PWA SYNC button ──
  document.body.addEventListener('click', function(e) {
    if (!e.target || e.target.id !== 'pwa-sync-btn') return;
    e.preventDefault();
    if (!('caches' in window)) { window.location.reload(); return; }
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(function(regs) {
        if (regs && regs.length) for (var i = 0; i < regs.length; i++) regs[i].unregister();
        return caches.keys();
      }).then(function(keys) {
        if (keys && keys.length) return Promise.all(keys.map(function(k) { return caches.delete(k); }));
      }).then(function() { window.location.reload(); }).catch(function() { window.location.reload(); });
    } else {
      caches.keys().then(function(keys) {
        if (keys && keys.length) return Promise.all(keys.map(function(k) { return caches.delete(k); }));
      }).then(function() { window.location.reload(); }).catch(function() { window.location.reload(); });
    }
  });
  window.API_INTERVALS = API_INTERVALS;
})();
</script>
<button type="button" class="pwa-sync-btn" id="pwa-sync-btn" title="Vider le cache et recharger" aria-label="Sync">SYNC</button>
<script>
async function syncVoyagerPortal() {
  try {
    const r = await fetch('/api/voyager-live');
    const data = await r.json();
    const box = document.getElementById('voyager-live-container');
    if (box && data.voyager_1) {
      box.innerHTML = `
        <div style="display:flex; flex-direction:column; gap:10px; width:100%;">
          <div style="border-left: 2px solid var(--amber); padding-left:10px; text-align:left;">
            <span style="color:var(--amber); font-size:0.8em;">V1 :</span> 
            <span style="color:#00ffcc;">${data.voyager_1.distance_km.toLocaleString('fr-FR')} KM</span>
          </div>
          <div style="border-left: 2px solid #ff4444; padding-left:10px; text-align:left;">
            <span style="color:#ff4444; font-size:0.8em;">V2 :</span> 
            <span style="color:#00ffcc;">${data.voyager_2 ? data.voyager_2.distance_km.toLocaleString('fr-FR') : '--'} KM</span>
          </div>
        </div>`;
    }
  } catch (e) { console.error("Liaison Portail Interrompue", e); }
}
syncVoyagerPortal();
setInterval(syncVoyagerPortal, window.API_INTERVALS.voyager);

async function loadSystemHealth() {
  try {
    var r = await fetch("/api/system/status");
    var d = await r.json();
    var el = document.getElementById("system-health-status");
    if (el) {
      el.innerHTML = "🟢 " + (d.system || "Orbital-Chohra") + " EN LIGNE<br>" +
        "Modules : " + (d.modules != null ? d.modules : "—") + "<br>" +
        "APIs : " + (d.apis != null ? d.apis : "—");
    }
  } catch (e) {
    var el = document.getElementById("system-health-status");
    if (el) el.innerHTML = "🔴 System status unavailable";
  }
}
setInterval(loadSystemHealth, window.API_INTERVALS.systemHealth);
loadSystemHealth();

async function loadDiagnostics() {
  try {
    var r = await fetch("/api/system/diagnostics");
    var d = await r.json();
    var el = document.getElementById("system-diagnostics");
    if (el) {
      el.innerHTML = "CPU: " + (d.cpu_percent != null ? d.cpu_percent : "—") + "%<br>" +
        "RAM: " + (d.memory_mb != null ? d.memory_mb : "—") + " MB<br>" +
        "Cache: " + (d.cache_entries != null ? d.cache_entries : "—");
    }
  } catch (e) {
    var el = document.getElementById("system-diagnostics");
    if (el) el.innerHTML = "Diagnostics unavailable";
  }
}
setInterval(loadDiagnostics, window.API_INTERVALS.diagnostics);
loadDiagnostics();
</script>
<script src="/static/js/astroscan_status_sync.js"></script>
<script src="/static/js/astroscan_status_ui.js"></script>
<script>
(function(){
  function apply(ev){
    var UI=window.AstroScanStatusUI;
    var d=ev.detail;
    if(d&&d._networkError){
      if(UI)UI.clear();
      var dot=document.getElementById("asc-portail-sync-dot");
      var txt=document.getElementById("asc-portail-sync-txt");
      if(txt)txt.textContent="/status indisponible";
      if(dot)dot.className="asc-portail-sync-dot off";
      return;
    }
    try {
      if(UI)UI.bind(d);
    } catch(eUi){}
    var dot=document.getElementById("asc-portail-sync-dot");
    var txt=document.getElementById("asc-portail-sync-txt");
    if(!txt)return;
    var pm=(d.production_mode!=null?String(d.production_mode):"").toUpperCase();
    txt.textContent=pm||(d.status||"—");
    if(dot){
      dot.className="asc-portail-sync-dot";
      if(pm==="LIVE")dot.classList.add("live");
      else if(pm==="DEMO")dot.classList.add("demo");
      else dot.classList.add("off");
    }
  }
  window.addEventListener("astroscan:status",apply);
  if(window.AstroScanStatusSync)AstroScanStatusSync.start({intervalMs:3000,useWebSocket:false});
})();
</script>

<script>
// MOBILE GRID FIX — applique apres chargement DOM
(function fixMobileGrid() {
  if (window.innerWidth > 768) return;
  function applyFix() {
    // Toutes les grilles
    document.querySelectorAll('[style*="repeat(3"]').forEach(el => {
      el.style.gridTemplateColumns = '1fr';
    });
    document.querySelectorAll('[style*="300px"]').forEach(el => {
      el.style.gridTemplateColumns = '1fr';
      el.style.width = '100%';
    });
    document.querySelectorAll('.portal-cards-grid').forEach(el => {
      el.style.gridTemplateColumns = '1fr 1fr';
      el.style.width = '100%';
    });
    document.querySelectorAll('.card, .nav-card, .portal-card').forEach(el => {
      el.style.width = '100%';
      el.style.maxWidth = '100%';
      el.style.minWidth = 'unset';
    });
  }
  // Appliquer immediatement et apres chaque rendu
  applyFix();
  setTimeout(applyFix, 500);
  setTimeout(applyFix, 1500);
  const obs = new MutationObserver(applyFix);
  obs.observe(document.body, {childList: true, subtree: true});
})();
</script>

<script>
(function(){
  if(window.innerWidth > 900) return;
  function force2col(){
    document.querySelectorAll('.portal-cards-grid').forEach(function(g){
      g.style.setProperty('grid-template-columns','1fr 1fr','important');
      g.style.setProperty('display','grid','important');
    });
  }
  force2col();
  document.addEventListener('DOMContentLoaded', force2col);
  window.addEventListener('load', force2col);
  var pcg = document.querySelector('.portal-cards-grid');
  if(pcg){
    var obs2 = new MutationObserver(function(){ force2col(); });
    obs2.observe(pcg, {attributes:true, attributeFilter:['style','class']});
  }
  var n=0, t=setInterval(function(){ force2col(); if(++n>10) clearInterval(t); },500);
})();
</script>

<script>
// GEO-IP AUTO-LOG
(function(){
  try {
    fetch('/api/visitors/log', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({path: window.location.pathname})
    });
  } catch(e) {}
})();
</script>

<!-- AEGIS Chat Widget -->
<script src="/static/js/astro_notifications.js"></script>
<script src="/static/js/aegis_chat_widget.js"></script>
<script>
(function(){
  if(window.innerWidth > 900) return;
  var g = document.getElementById('pcg-mobile') || document.querySelector('.portal-cards-grid');
  if(!g) return;
  g.style.cssText = 'display:grid!important;grid-template-columns:1fr 1fr!important;gap:6px!important;width:100%!important;padding:0!important;margin-top:0!important;box-sizing:border-box!important;overflow:visible!important;';
  var cards = g.querySelectorAll('.card, [class*="card"]');
  cards.forEach(function(c){
    c.style.cssText = 'min-height:85px!important;height:auto!important;width:auto!important;padding:10px 8px!important;font-size:0.72rem!important;clip-path:none!important;margin:0!important;box-sizing:border-box!important;';
  });
})();
</script>
